---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Fixed particle canvas background -->
  <canvas id="bg-canvas"></canvas>

  <!-- Dark header overlay -->
  <Header />

  <main>

    <!-- HERO: pure animation viewport, NO text on top -->
    <section class="hero">
      <!-- Minimal HUD — bottom corners only -->
      <div class="hud-corner hud-tl">
        <span class="hud-mono">ALICE · Pb+Pb · √s=13 TeV</span>
      </div>
      <div class="hud-corner hud-tr">
        <span class="hud-mono">N₀ tracks: <span id="track-count">0</span></span>
      </div>
      <div class="hud-corner hud-br">
        <span class="hud-mono hint-pulse">↓ scroll to explore</span>
      </div>
      <div class="hud-corner hud-bl">
        <span class="hud-mono hint-click">⊕ click to collide</span>
      </div>

      <!-- Particle legend — right side -->
      <div class="hud-legend">
        <div class="legend-title">PARTICLES</div>
        <div class="legend-item"><span class="legend-dot" style="background:#00e5ff"></span><span class="legend-name">Electron</span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#ff7043"></span><span class="legend-name">Pion</span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#ce93d8"></span><span class="legend-name">Muon</span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#66bb6a"></span><span class="legend-name">Kaon</span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#ffee58"></span><span class="legend-name">Photon</span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#ef5350"></span><span class="legend-name">Proton</span></div>
      </div>
    </section>

    <!-- PARALLAX CONTENT: slides up over the fixed canvas -->
    <div class="content-area">

      <!-- INTRO CARD — first thing visible on scroll -->
      <section class="intro-section">
        <div class="section-inner">
          <div class="badge">
            <span class="badge-dot"></span>
            ALICE Experiment · CERN · Münster
          </div>
          <h1>Hi, I'm<br><span class="name">Madhva Fakare</span></h1>
          <p class="tagline">MSc Physics student building machine learning pipelines for electron-pion separation using the Transition Radiation Detector at CERN.</p>
          <div class="hero-actions">
            <a href="/assistant" class="btn-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
              Physics AI Assistant
            </a>
            <a href="https://github.com/madhva8" target="_blank" class="btn-secondary">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              GitHub
            </a>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-inner">
          <div class="section-label">Current Research</div>
          <h2>TRD Electron-Pion Separation</h2>
          <div class="research-grid">
            <div class="research-card main-card">
              <div class="card-top">
                <div class="card-icon">🔬</div>
                <div>
                  <div class="card-title">ALICE Experiment · CERN</div>
                  <div class="card-sub">Run 3 Data Analysis · lxplus servers</div>
                </div>
                <a href="https://github.com/madhva8/alice-trd-analysis" target="_blank" class="github-btn">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                  Repo
                </a>
              </div>
              <p class="card-desc">Developing an analysis pipeline for particle identification using the ALICE Transition Radiation Detector. Working with O2Physics, ROOT framework, and real Run 3 experimental data on CERN lxplus servers.</p>
              <div class="tags">
                <span>ROOT</span><span>O2Physics</span><span>C++</span>
                <span>BDT / ML</span><span>CERN lxplus</span><span>Run 3</span>
              </div>
            </div>
            <div class="stat-cards">
              <div class="stat-card">
                <div class="stat-num">Run 3</div>
                <div class="stat-label">ALICE Data</div>
              </div>
              <div class="stat-card">
                <div class="stat-num">TRD</div>
                <div class="stat-label">Detector</div>
              </div>
              <div class="stat-card">
                <div class="stat-num">BDT</div>
                <div class="stat-label">ML Method</div>
              </div>
              <div class="stat-card">
                <div class="stat-num">e/π</div>
                <div class="stat-label">Separation</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section alt">
        <div class="section-inner">
          <div class="section-label">About Me</div>
          <h2>Who I Am</h2>

          <div class="about-bio">
            <div class="about-text-block">
              <p>I'm a Master's student in Physics at the <strong>University of Münster</strong>, originally from India. My thesis sits at the intersection of experimental particle physics and machine learning — I'm building a pipeline to separate electrons from pions using the Transition Radiation Detector inside the ALICE experiment at CERN.</p>
              <p>What draws me to this problem is the scale of it: heavy-ion collisions at the LHC recreate conditions from microseconds after the Big Bang, and the TRD is one of the key detectors helping us understand what comes out. Getting the particle identification right matters for the physics.</p>
              <p>Day-to-day, I work with real Run 3 data on CERN's <strong>lxplus</strong> servers, writing analysis code in the O2Physics framework, building ROOT macros, and training Boosted Decision Trees to distinguish particle signatures from raw detector signals.</p>
            </div>

            <div class="about-cards">
              <div class="about-card">
                <div class="about-card-icon">🎓</div>
                <div>
                  <div class="about-card-title">Education</div>
                  <div class="about-card-body">MSc Physics<br><span class="muted">University of Münster, Germany</span></div>
                </div>
              </div>
              <div class="about-card">
                <div class="about-card-icon">⚛️</div>
                <div>
                  <div class="about-card-title">Experiment</div>
                  <div class="about-card-body">ALICE · LHC · CERN<br><span class="muted">Run 3 data · Pb+Pb collisions</span></div>
                </div>
              </div>
              <div class="about-card">
                <div class="about-card-icon">🔬</div>
                <div>
                  <div class="about-card-title">Focus</div>
                  <div class="about-card-body">Electron-pion separation<br><span class="muted">TRD · Boosted Decision Trees</span></div>
                </div>
              </div>
              <div class="about-card">
                <div class="about-card-icon">💻</div>
                <div>
                  <div class="about-card-title">Tools</div>
                  <div class="about-card-body">O2Physics · ROOT · C++<br><span class="muted">Python · Git · lxplus / CVMFS</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-inner">
          <div class="section-label">Connect</div>
          <h2>Find Me</h2>
          <div class="link-grid">
            <a href="https://github.com/madhva8" target="_blank" class="link-card">
              <div class="link-icon-wrap">
                <svg viewBox="0 0 16 16" width="22" height="22" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              </div>
              <div class="link-info">
                <div class="link-title">GitHub</div>
                <div class="link-sub">alice-trd-analysis</div>
              </div>
              <span class="link-arr">→</span>
            </a>
            <a href="mailto:madhva.fakare@cern.ch" class="link-card">
              <div class="link-icon-wrap">📧</div>
              <div class="link-info">
                <div class="link-title">Email</div>
                <div class="link-sub">madhva.fakare@cern.ch</div>
              </div>
              <span class="link-arr">→</span>
            </a>
            <a href="/blog" class="link-card">
              <div class="link-icon-wrap">📝</div>
              <div class="link-info">
                <div class="link-title">Research Blog</div>
                <div class="link-sub">Notes & updates</div>
              </div>
              <span class="link-arr">→</span>
            </a>
            <a href="/assistant" class="link-card featured">
              <div class="link-icon-wrap">⚛</div>
              <div class="link-info">
                <div class="link-title">Physics AI Assistant</div>
                <div class="link-sub">Powered by Gemini & DeepSeek</div>
              </div>
              <span class="link-arr">→</span>
            </a>
          </div>
        </div>
      </section>

    </div><!-- /content-area -->
  </main>

  <Footer />

</body>
</html>

<script is:inline>
(function () {
  const canvas = document.getElementById('bg-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, cx, cy, R;

  // ── Offscreen canvas for the static detector geometry ──
  const detCanvas = document.createElement('canvas');
  const dctx = detCanvas.getContext('2d');
  let detDirty = true; // rebuild when resized

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W/2; cy = H/2;
    R  = Math.min(W, H) * 0.46;
    detCanvas.width  = W;
    detCanvas.height = H;
    detDirty = true;
  }
  resize();
  window.addEventListener('resize', resize);

  // ── Detector radii as fractions of R ──
  const D = {
    beamPipe:   0.034,
    itsInner:   0.062,
    itsOuter:   0.148,
    tpcInner:   0.165,
    tpcOuter:   0.530,
    trdInner:   0.550,
    trdOuter:   0.710,
    tofInner:   0.720,
    tofOuter:   0.780,
    emcalInner: 0.800,
    emcalOuter: 0.930,
  };
  const N_TRD = 18;

  // ── Colours ──
  const C = {
    electron: '#00e5ff',
    pion:     '#ff7043',
    muon:     '#ce93d8',
    kaon:     '#66bb6a',
    photon:   '#ffee58',
    proton:   '#ef5350',
  };
  const cArr = Object.values(C);
  const rC = () => cArr[Math.floor(Math.random()*cArr.length)];

  // Pre-parsed RGB components for each colour (avoid per-frame hex parsing)
  const CRGB = {};
  for (const [k,v] of Object.entries(C)) {
    CRGB[k] = [parseInt(v.slice(1,3),16), parseInt(v.slice(3,5),16), parseInt(v.slice(5,7),16)];
  }
  function rgba(hex, a) {
    const r=parseInt(hex.slice(1,3),16), g=parseInt(hex.slice(3,5),16), b=parseInt(hex.slice(5,7),16);
    return `rgba(${r},${g},${b},${a.toFixed(2)})`;
  }

  // ─────────────────────────────────────────────
  //  BUILD DETECTOR — drawn once to offscreen canvas
  // ─────────────────────────────────────────────
  function buildDetector() {
    const c = dctx;
    c.clearRect(0,0,W,H);
    const ri = f => f * R;

    // Background
    c.fillStyle = 'rgb(2,5,14)';
    c.fillRect(0,0,W,H);

    // ── TPC bulk fill ──
    c.beginPath();
    c.arc(cx,cy,ri(D.tpcOuter),0,Math.PI*2);
    c.arc(cx,cy,ri(D.tpcInner),0,Math.PI*2,true);
    c.fillStyle='rgba(4,18,38,0.60)'; c.fill();

    // TPC pad rows — batch ALL into one path per colour to save ctx calls
    c.beginPath();
    const tpcStep = 16; // fewer rings, still looks great
    for (let p=0; p<=tpcStep; p++) {
      const r2 = ri(D.tpcInner) + (ri(D.tpcOuter)-ri(D.tpcInner))*p/tpcStep;
      c.moveTo(cx+r2, cy); c.arc(cx,cy,r2,0,Math.PI*2);
    }
    c.strokeStyle='rgba(0,140,220,0.07)'; c.lineWidth=0.6; c.stroke();

    // TPC radial sectors — single path
    c.beginPath();
    for (let s=0; s<18; s++) {
      const a=Math.PI*2*s/18;
      c.moveTo(cx+ri(D.tpcInner)*Math.cos(a), cy+ri(D.tpcInner)*Math.sin(a));
      c.lineTo(cx+ri(D.tpcOuter)*Math.cos(a), cy+ri(D.tpcOuter)*Math.sin(a));
    }
    c.strokeStyle='rgba(0,140,220,0.05)'; c.lineWidth=0.5; c.stroke();

    // TPC boundary
    c.beginPath(); c.arc(cx,cy,ri(D.tpcOuter),0,Math.PI*2);
    c.strokeStyle='rgba(0,170,255,0.28)'; c.lineWidth=1.2; c.stroke();
    c.beginPath(); c.arc(cx,cy,ri(D.tpcInner),0,Math.PI*2);
    c.strokeStyle='rgba(0,170,255,0.18)'; c.lineWidth=0.8; c.stroke();

    // ── ITS layers ──
    c.beginPath();
    c.arc(cx,cy,ri(D.itsOuter),0,Math.PI*2);
    c.arc(cx,cy,ri(D.itsInner),0,Math.PI*2,true);
    c.fillStyle='rgba(0,28,52,0.45)'; c.fill();
    [0.067,0.082,0.098,0.114,0.128,0.140,0.148].forEach((f,i) => {
      c.beginPath(); c.arc(cx,cy,ri(f),0,Math.PI*2);
      c.strokeStyle=`rgba(0,210,255,${(0.30-i*0.028).toFixed(2)})`; c.lineWidth=1; c.stroke();
    });

    // ── TRD supermodules (18 × 6 layers) ──
    const trdR0=ri(D.trdInner), trdR1=ri(D.trdOuter);
    const trdFills=['rgba(0,38,18,0.70)','rgba(0,48,22,0.70)','rgba(0,58,28,0.70)',
                    'rgba(0,68,33,0.70)','rgba(0,78,38,0.70)','rgba(0,88,43,0.70)'];
    // Draw all cells of same layer colour in one pass
    for (let lay=0; lay<6; lay++) {
      c.beginPath();
      for (let sm=0; sm<N_TRD; sm++) {
        const a0=Math.PI*2*sm/N_TRD, a1=Math.PI*2*(sm+1)/N_TRD;
        const r0=trdR0+(trdR1-trdR0)*lay/6, r1=trdR0+(trdR1-trdR0)*(lay+1)/6;
        c.arc(cx,cy,r1,a0,a1); c.arc(cx,cy,r0,a1,a0,true); c.closePath();
      }
      c.fillStyle=trdFills[lay]; c.fill();
      c.strokeStyle='rgba(0,180,70,0.10)'; c.lineWidth=0.4; c.stroke();
    }
    // TRD supermodule walls — single path
    c.beginPath();
    for (let sm=0; sm<N_TRD; sm++) {
      const a=Math.PI*2*sm/N_TRD;
      c.moveTo(cx+trdR0*Math.cos(a), cy+trdR0*Math.sin(a));
      c.lineTo(cx+trdR1*Math.cos(a), cy+trdR1*Math.sin(a));
    }
    c.strokeStyle='rgba(0,220,80,0.28)'; c.lineWidth=0.8; c.stroke();
    // TRD layer rings — single path
    c.beginPath();
    for (let lay=1; lay<6; lay++) {
      const lr=trdR0+(trdR1-trdR0)*lay/6;
      c.moveTo(cx+lr,cy); c.arc(cx,cy,lr,0,Math.PI*2);
    }
    c.strokeStyle='rgba(0,200,70,0.09)'; c.lineWidth=0.5; c.stroke();
    // TRD outer/inner boundary
    c.beginPath(); c.arc(cx,cy,trdR1,0,Math.PI*2);
    c.strokeStyle='rgba(0,220,80,0.55)'; c.lineWidth=1.5; c.stroke();
    c.beginPath(); c.arc(cx,cy,trdR0,0,Math.PI*2);
    c.strokeStyle='rgba(0,220,80,0.35)'; c.lineWidth=1; c.stroke();
    // SM labels
    c.font=`${Math.max(7,R*0.018)}px monospace`;
    c.textAlign='center'; c.textBaseline='middle'; c.fillStyle='rgba(0,220,80,0.32)';
    for (let sm=0; sm<N_TRD; sm+=3) {
      const amid=Math.PI*2*(sm+0.5)/N_TRD, lr=(trdR0+trdR1)/2;
      c.fillText(`SM${sm}`, cx+lr*Math.cos(amid), cy+lr*Math.sin(amid));
    }

    // ── TOF ──
    c.beginPath();
    c.arc(cx,cy,ri(D.tofOuter),0,Math.PI*2);
    c.arc(cx,cy,ri(D.tofInner),0,Math.PI*2,true);
    c.fillStyle='rgba(8,8,48,0.55)'; c.fill();
    c.beginPath();
    for (let s=0; s<18; s++) {
      const a=Math.PI*2*s/18;
      c.moveTo(cx+ri(D.tofInner)*Math.cos(a), cy+ri(D.tofInner)*Math.sin(a));
      c.lineTo(cx+ri(D.tofOuter)*Math.cos(a), cy+ri(D.tofOuter)*Math.sin(a));
    }
    c.strokeStyle='rgba(80,140,255,0.18)'; c.lineWidth=0.7; c.stroke();
    c.beginPath(); c.arc(cx,cy,ri(D.tofOuter),0,Math.PI*2);
    c.strokeStyle='rgba(80,140,255,0.38)'; c.lineWidth=1.2; c.stroke();
    c.beginPath(); c.arc(cx,cy,ri(D.tofInner),0,Math.PI*2);
    c.strokeStyle='rgba(80,140,255,0.22)'; c.lineWidth=0.7; c.stroke();

    // ── EMCal (partial arc) ──
    const emA0=Math.PI*0.82, emA1=Math.PI*1.18;
    c.beginPath();
    c.arc(cx,cy,ri(D.emcalOuter),emA0,emA1);
    c.arc(cx,cy,ri(D.emcalInner),emA1,emA0,true);
    c.closePath();
    c.fillStyle='rgba(38,8,38,0.58)'; c.fill();
    c.strokeStyle='rgba(180,80,220,0.32)'; c.lineWidth=1; c.stroke();
    c.beginPath();
    for (let t=0; t<=14; t++) {
      const a=emA0+(emA1-emA0)*t/14;
      c.moveTo(cx+ri(D.emcalInner)*Math.cos(a), cy+ri(D.emcalInner)*Math.sin(a));
      c.lineTo(cx+ri(D.emcalOuter)*Math.cos(a), cy+ri(D.emcalOuter)*Math.sin(a));
    }
    c.strokeStyle='rgba(180,80,220,0.13)'; c.lineWidth=0.5; c.stroke();

    // ── Beam pipe ──
    c.beginPath(); c.arc(cx,cy,ri(D.beamPipe),0,Math.PI*2);
    c.strokeStyle='rgba(255,80,80,0.55)'; c.lineWidth=2; c.stroke();
    c.beginPath(); c.moveTo(0,cy); c.lineTo(W,cy);
    c.strokeStyle='rgba(255,80,80,0.10)'; c.lineWidth=1.5; c.stroke();
    c.beginPath(); c.arc(cx,cy,ri(0.012),0,Math.PI*2);
    c.fillStyle='rgba(255,120,120,0.35)'; c.fill();
    c.strokeStyle='rgba(255,160,160,0.75)'; c.lineWidth=1.5; c.stroke();

    // ── Labels ──
    const labels=[
      {lbl:'ITS', r:D.itsOuter*0.82,  a:-0.28, col:'rgba(0,210,255,0.55)'},
      {lbl:'TPC', r:(D.tpcInner+D.tpcOuter)/2, a:-0.20, col:'rgba(0,170,255,0.45)'},
      {lbl:'TRD', r:(D.trdInner+D.trdOuter)/2, a:-0.22, col:'rgba(0,220,80,0.65)'},
      {lbl:'TOF', r:(D.tofInner+D.tofOuter)/2, a:-0.24, col:'rgba(80,140,255,0.58)'},
      {lbl:'EMCal',r:(D.emcalInner+D.emcalOuter)/2, a:Math.PI*0.99, col:'rgba(180,80,220,0.55)'},
    ];
    c.font=`bold ${Math.max(10,R*0.032)}px JetBrains Mono, monospace`;
    c.textBaseline='middle';
    labels.forEach(l => {
      const lx=cx+l.r*R*Math.cos(l.a)+6, ly=cy+l.r*R*Math.sin(l.a);
      c.textAlign=(l.lbl==='EMCal')?'center':'left';
      c.fillStyle=l.col;
      c.fillText(l.lbl, lx, ly);
    });
    c.textAlign='left'; c.textBaseline='alphabetic';
  }

  // ─────────────────────────────────────────────
  //  TRACKS — pre-computed arcs, revealed over time
  // ─────────────────────────────────────────────
  function makeTrack(angle) {
    const t=Math.random();
    let color, maxR, curv;
    if      (t<0.18){color=C.electron;maxR=(D.tofOuter+0.05)*R;curv=(Math.random()>0.5?1:-1)*(0.012+Math.random()*0.016);}
    else if (t<0.38){color=C.pion;    maxR=(D.trdOuter+0.01)*R;curv=(Math.random()>0.5?1:-1)*(0.005+Math.random()*0.010);}
    else if (t<0.52){color=C.muon;    maxR=(D.emcalInner+0.03)*R;curv=(Math.random()>0.5?1:-1)*0.005;}
    else if (t<0.64){color=C.kaon;    maxR=(D.trdInner+Math.random()*0.1)*R;curv=(Math.random()>0.5?1:-1)*0.012;}
    else if (t<0.76){color=C.photon;  maxR=D.tpcOuter*0.7*R;curv=0;}
    else            {color=C.proton;  maxR=D.tpcOuter*0.85*R;curv=(Math.random()>0.5?1:-1)*(0.012+Math.random()*0.016);}

    // Step size: smaller = denser points = smoother slow reveal
    const step = 1.5;
    const pts=[];
    let vx=Math.cos(angle)*step, vy=Math.sin(angle)*step;
    let px=cx, py=cy;
    let prevDistSq = 0;
    while (pts.length<600) {
      if (curv!==0) {
        const spd=Math.sqrt(vx*vx+vy*vy);
        const a2=Math.atan2(vy,vx)+curv;
        vx=Math.cos(a2)*spd; vy=Math.sin(a2)*spd;
      }
      px+=vx; py+=vy;
      const distSq=(px-cx)**2+(py-cy)**2;
      if (distSq >= maxR*maxR) break;
      if (distSq >= (D.tofOuter*0.97*R)**2) break;
      if (px<0||px>W||py<0||py>H) break;
      // Stop if track starts curving back toward center (unphysical loop)
      if (pts.length > 4 && distSq < prevDistSq * 0.98) break;
      prevDistSq = distSq;
      pts.push(px, py);
    }
    return {pts, color, drawTo:0, width:0.9+Math.random()*0.8};
  }

  // ─────────────────────────────────────────────
  //  HITS
  // ─────────────────────────────────────────────
  let hits=[];
  function spawnHits(angle, color) {
    const ri=f=>f*R;
    // ITS: 4 hits max
    [0.068,0.085,0.110,0.142].forEach(f=>{
      if(Math.random()>0.3) hits.push({type:'ITS',r:ri(f),a:angle+(Math.random()-0.5)*0.05,color,age:0,lt:90});
    });
    // TPC: just 8 sparse clusters (not 24)
    for(let p=0;p<8;p++){
      const fr=D.tpcInner+(D.tpcOuter-D.tpcInner)*p/8;
      hits.push({type:'TPC',r:ri(fr),a:angle+(Math.random()-0.5)*0.07,color,age:0,lt:90});
    }
    // TRD: 6 tracklets
    for(let lay=0;lay<6;lay++){
      const fr=D.trdInner+(D.trdOuter-D.trdInner)*(lay+0.5)/6;
      hits.push({type:'TRD',r:ri(fr),a:angle+(Math.random()-0.5)*0.025,age:0,lt:140,lay});
    }
    // TOF: 1
    if(Math.random()>0.3)
      hits.push({type:'TOF',r:ri((D.tofInner+D.tofOuter)/2),a:angle+(Math.random()-0.5)*0.02,age:0,lt:160});
  }

  function drawHits() {
    // Draw all same-type hits together to minimise state changes
    const trd=[],tof=[],tpc=[],its=[];
    hits=hits.filter(h=>{ h.age++; return h.age<h.lt; });
    for(const h of hits){
      if(h.type==='TRD') trd.push(h);
      else if(h.type==='TOF') tof.push(h);
      else if(h.type==='TPC') tpc.push(h);
      else its.push(h);
    }
    // TPC dots — all same colour to batch
    for(const h of tpc){
      const fade=1-h.age/h.lt;
      const hx=cx+h.r*Math.cos(h.a), hy=cy+h.r*Math.sin(h.a);
      ctx.beginPath(); ctx.arc(hx,hy,R*0.004,0,Math.PI*2);
      ctx.fillStyle=rgba(h.color, fade*0.55); ctx.fill();
    }
    // ITS squares
    for(const h of its){
      const fade=1-h.age/h.lt, s=R*0.009;
      const hx=cx+h.r*Math.cos(h.a), hy=cy+h.r*Math.sin(h.a);
      ctx.fillStyle=rgba(h.color, fade*0.85);
      ctx.fillRect(hx-s/2,hy-s/2,s,s);
    }
    // TRD tracklets — no shadowBlur, use bright fill instead
    for(const h of trd){
      const fade=1-h.age/h.lt;
      const hx=cx+h.r*Math.cos(h.a), hy=cy+h.r*Math.sin(h.a);
      const hw=R*0.020, hh=R*0.009;
      ctx.save();
      ctx.translate(hx,hy); ctx.rotate(h.a+Math.PI/2);
      ctx.fillStyle=`rgba(0,255,128,${(fade*0.92).toFixed(2)})`;
      ctx.fillRect(-hw/2,-hh/2,hw,hh);
      ctx.restore();
    }
    // TOF circles
    for(const h of tof){
      const fade=1-h.age/h.lt;
      const hx=cx+h.r*Math.cos(h.a), hy=cy+h.r*Math.sin(h.a);
      ctx.beginPath(); ctx.arc(hx,hy,R*0.009,0,Math.PI*2);
      ctx.fillStyle=`rgba(120,190,255,${(fade*0.90).toFixed(2)})`; ctx.fill();
    }
  }

  // ─────────────────────────────────────────────
  //  STATE
  // ─────────────────────────────────────────────
  let tracks=[], beams=[], glow=0, autoT=0;
  const trackEl=document.getElementById('track-count');

  function triggerCollision() {
    glow=1; beams=[];
    const n=18+Math.floor(Math.random()*8); // cap at ~26 tracks
    for(let i=0;i<n;i++){
      const angle=Math.PI*2*i/n+(Math.random()-0.5)*0.35;
      tracks.push(makeTrack(angle));
      spawnHits(angle, rC());
    }
    setTimeout(spawnBeams, 2400);
  }

  function spawnBeams() {
    beams=[];
    for(let i=0;i<2;i++){
      beams.push({x:-30,y:cy+(i-0.5)*5,vx:9,trail:[]});
      beams.push({x:W+30,y:cy+(i-0.5)*5,vx:-9,trail:[]});
    }
  }

  canvas.addEventListener('click',()=>triggerCollision());
  canvas.addEventListener('touchend',e=>{e.preventDefault();triggerCollision();},{passive:false});

  // ─────────────────────────────────────────────
  //  MAIN LOOP
  // ─────────────────────────────────────────────
  let hidden=false;
  document.addEventListener('visibilitychange',()=>{ hidden=document.hidden; });

  function loop() {
    requestAnimationFrame(loop);
    if(hidden) return; // don't burn CPU when tab not visible

    // Rebuild detector onto offscreen canvas only when needed
    if(detDirty){ buildDetector(); detDirty=false; }

    // Clear full canvas, then stamp detector
    ctx.clearRect(0, 0, W, H);
    ctx.drawImage(detCanvas, 0, 0);

    // Collision flash — no radialGradient every frame unless active
    if(glow>0){
      const gr=ctx.createRadialGradient(cx,cy,0,cx,cy,R*0.35);
      gr.addColorStop(0,`rgba(255,245,150,${(glow*0.60).toFixed(2)})`);
      gr.addColorStop(0.5,`rgba(80,160,255,${(glow*0.15).toFixed(2)})`);
      gr.addColorStop(1,'transparent');
      ctx.fillStyle=gr; ctx.fillRect(0,0,W,H);
      glow-=0.028;
      if(glow<0)glow=0;
    }

    // Beams
    let fired=false;
    beams=beams.filter(b=>{
      b.trail.push({x:b.x,y:b.y});
      if(b.trail.length>12)b.trail.shift();
      b.x+=b.vx;
      const L=beams.filter(bb=>bb.vx>0), Ri=beams.filter(bb=>bb.vx<0);
      if(!fired&&L.length&&Ri.length&&L[0].x+12>=Ri[0].x){fired=true;triggerCollision();return false;}
      ctx.beginPath();
      b.trail.forEach((pt,i)=>i===0?ctx.moveTo(pt.x,pt.y):ctx.lineTo(pt.x,pt.y));
      ctx.lineTo(b.x,b.y);
      ctx.strokeStyle='#ff4466';ctx.lineWidth=1.5;ctx.globalAlpha=0.72;ctx.stroke();ctx.globalAlpha=1;
      ctx.beginPath();ctx.arc(b.x,b.y,3,0,Math.PI*2);
      ctx.fillStyle='rgba(255,68,102,0.9)';ctx.fill(); // no shadowBlur
      return b.x>-50&&b.x<W+50;
    });

    // Clip drawing to detector boundary — nothing can appear outside the ring
    ctx.save();
    ctx.beginPath();
    ctx.arc(cx, cy, D.emcalOuter * R, 0, Math.PI * 2);
    ctx.clip();

    // Hits and tracks all clipped to detector boundary
    drawHits();

    // Tracks — reveal progressively, draw full trail from origin with fade
    const STEP=1.5;
    tracks=tracks.filter(tr=>{
      tr.drawTo=Math.min(tr.pts.length, tr.drawTo+STEP*2);
      const end=tr.drawTo; // index into flat array (pairs)
      if(end<4) return true;

      // ── Full trail: draw in segments with increasing opacity toward tip ──
      const SEGS=12; // number of gradient segments along the trail
      const segLen=Math.max(4, Math.floor(end/SEGS/2)*2);
      for(let s=0;s<SEGS;s++){
        const iStart=Math.max(0, end - (SEGS-s)*segLen);
        const iEnd  =Math.max(0, end - (SEGS-s-1)*segLen);
        if(iEnd-iStart<2) continue;
        const alpha=0.08 + (s/SEGS)*0.80; // fades from 0.08 at tail to ~0.88 at tip
        ctx.beginPath();
        ctx.moveTo(tr.pts[iStart], tr.pts[iStart+1]);
        for(let i=iStart+2;i<=iEnd;i+=2)
          ctx.lineTo(tr.pts[i], tr.pts[i+1]);
        ctx.strokeStyle=tr.color;
        ctx.lineWidth=tr.width*(0.4+0.6*(s/SEGS)); // thinner at tail, full width at tip
        ctx.globalAlpha=alpha;
        ctx.stroke();
      }
      ctx.globalAlpha=1;

      // ── Bright leading dot at the tip ──
      const tipX=tr.pts[end-2], tipY=tr.pts[end-1];
      ctx.beginPath(); ctx.arc(tipX,tipY,tr.width*1.6,0,Math.PI*2);
      ctx.fillStyle=tr.color; ctx.globalAlpha=0.95; ctx.fill();
      ctx.globalAlpha=1;

      return tr.drawTo<tr.pts.length;
    });

    ctx.restore(); // end clip region
    if(trackEl) trackEl.textContent=tracks.length;

    autoT++;
    if(tracks.length===0&&beams.length===0&&autoT>200){spawnBeams();autoT=0;}
    if(tracks.length>0||beams.length>0)autoT=0;
  }

  spawnBeams();
  loop();
})();
</script>

