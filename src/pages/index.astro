---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Fixed particle canvas background -->
  <canvas id="bg-canvas"></canvas>

  <!-- Dark header overlay -->
  <Header />

  <main>

    <!-- HERO: full-screen, content over canvas -->
    <section class="hero">
      <div class="hero-content">
        <div class="badge">
          <span class="badge-dot"></span>
          ALICE Experiment · CERN · Münster
        </div>
        <h1>
          Hi, I'm<br>
          <span class="name">Madhva Fakare</span>
        </h1>
        <p class="tagline">
          MSc Physics student building machine learning pipelines<br class="br-desktop">
          for electron-pion separation using the TRD at CERN.
        </p>
        <div class="hero-actions">
          <a href="/assistant" class="btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
            Physics AI Assistant
          </a>
          <a href="https://github.com/madhva8" target="_blank" class="btn-secondary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
        </div>
        <div class="hero-hint">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
          Click anywhere to trigger a particle collision
        </div>
      </div>

      <!-- HUD overlay: detector info -->
      <div class="detector-hud">
        <div class="hud-item">
          <span class="hud-label">Experiment</span>
          <span class="hud-value">ALICE · LHC</span>
        </div>
        <div class="hud-item">
          <span class="hud-label">Collision</span>
          <span class="hud-value">Pb+Pb</span>
        </div>
        <div class="hud-item">
          <span class="hud-label">Energy</span>
          <span class="hud-value">√s = 5.5 TeV</span>
        </div>
        <div class="hud-item">
          <span class="hud-label">Tracks</span>
          <span class="hud-value" id="track-count">0</span>
        </div>
      </div>

      <div class="scroll-indicator">
        <span>Scroll</span>
        <div class="scroll-arrow"></div>
      </div>
    </section>

    <!-- CONTENT SECTIONS on white background -->
    <div class="content-area">

      <section class="section">
        <div class="section-inner">
          <div class="section-label">Current Research</div>
          <h2>TRD Electron-Pion Separation</h2>
          <div class="research-grid">
            <div class="research-card main-card">
              <div class="card-top">
                <div class="card-icon">🔬</div>
                <div>
                  <div class="card-title">ALICE Experiment · CERN</div>
                  <div class="card-sub">Run 3 Data Analysis · lxplus servers</div>
                </div>
                <a href="https://github.com/madhva8/alice-trd-analysis" target="_blank" class="github-btn">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                  Repo
                </a>
              </div>
              <p class="card-desc">Developing an analysis pipeline for particle identification using the ALICE Transition Radiation Detector. Working with O2Physics, ROOT framework, and real Run 3 experimental data on CERN lxplus servers.</p>
              <div class="tags">
                <span>ROOT</span><span>O2Physics</span><span>C++</span>
                <span>BDT / ML</span><span>CERN lxplus</span><span>Run 3</span>
              </div>
            </div>
            <div class="stat-cards">
              <div class="stat-card">
                <div class="stat-num">Run 3</div>
                <div class="stat-label">ALICE Data</div>
              </div>
              <div class="stat-card">
                <div class="stat-num">TRD</div>
                <div class="stat-label">Detector</div>
              </div>
              <div class="stat-card">
                <div class="stat-num">BDT</div>
                <div class="stat-label">ML Method</div>
              </div>
              <div class="stat-card">
                <div class="stat-num">e/π</div>
                <div class="stat-label">Separation</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section alt">
        <div class="section-inner">
          <div class="section-label">About Me</div>
          <h2>Background</h2>
          <div class="about-grid">
            <p class="about-text">I'm a Master's student in Physics working on my thesis focused on <strong>electron-pion separation</strong> using the Transition Radiation Detector (TRD) in the ALICE experiment at CERN. I work with real Run 3 data using machine learning techniques including Boosted Decision Trees for particle identification.</p>
            <div class="about-pills">
              <div class="pill">📍 Münster, Germany</div>
              <div class="pill">🎓 MSc Physics</div>
              <div class="pill">⚛ ALICE/CERN</div>
              <div class="pill">💻 O2Physics · ROOT</div>
              <div class="pill">🤖 ML / BDT</div>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-inner">
          <div class="section-label">Connect</div>
          <h2>Find Me</h2>
          <div class="link-grid">
            <a href="https://github.com/madhva8" target="_blank" class="link-card">
              <div class="link-icon-wrap">
                <svg viewBox="0 0 16 16" width="22" height="22" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              </div>
              <div class="link-info">
                <div class="link-title">GitHub</div>
                <div class="link-sub">alice-trd-analysis</div>
              </div>
              <span class="link-arr">→</span>
            </a>
            <a href="mailto:madhva.fakare@cern.ch" class="link-card">
              <div class="link-icon-wrap">📧</div>
              <div class="link-info">
                <div class="link-title">Email</div>
                <div class="link-sub">madhva.fakare@cern.ch</div>
              </div>
              <span class="link-arr">→</span>
            </a>
            <a href="/blog" class="link-card">
              <div class="link-icon-wrap">📝</div>
              <div class="link-info">
                <div class="link-title">Research Blog</div>
                <div class="link-sub">Notes & updates</div>
              </div>
              <span class="link-arr">→</span>
            </a>
            <a href="/assistant" class="link-card featured">
              <div class="link-icon-wrap">⚛</div>
              <div class="link-info">
                <div class="link-title">Physics AI Assistant</div>
                <div class="link-sub">Powered by Gemini & DeepSeek</div>
              </div>
              <span class="link-arr">→</span>
            </a>
          </div>
        </div>
      </section>

    </div><!-- /content-area -->
  </main>

  <Footer />

</body>
</html>

<script is:inline>
(function () {
  const canvas = document.getElementById('bg-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, cx, cy, R;

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W/2; cy = H/2;
    // R fills ~90% of the smaller dimension so detector is BIG
    R = Math.min(W, H) * 0.48;
  }
  resize();
  window.addEventListener('resize', resize);

  // ── Detector radii as fractions of R (realistic ALICE proportions) ──
  const D = {
    beamPipe:  0.034,  // ~3 cm
    itsInner:  0.062,  // ITS inner layer ~5.6 cm
    itsOuter:  0.148,  // ITS outer layer ~43 cm (simplified)
    tpcInner:  0.165,  // TPC inner field cage
    tpcOuter:  0.530,  // TPC outer field cage
    trdInner:  0.550,  // TRD inner
    trdOuter:  0.710,  // TRD outer (6 layers x ~3.5cm each)
    tofInner:  0.720,
    tofOuter:  0.780,
    emcalInner:0.800,
    emcalOuter:0.930,
  };
  const N_TRD = 18; // supermodules
  const N_TPC_PAD = 72; // TPC pad rows (visual)
  const ITS_LAYERS = 7; // ITS7 for Run3

  // ── Colours ──
  const C = {
    electron: '#00e5ff',
    pion:     '#ff7043',
    muon:     '#ce93d8',
    kaon:     '#66bb6a',
    photon:   '#ffee58',
    proton:   '#ef5350',
  };
  const cArr = Object.values(C);
  const rC = () => cArr[Math.floor(Math.random()*cArr.length)];

  function hexRgb(h) {
    return [parseInt(h.slice(1,3),16), parseInt(h.slice(3,5),16), parseInt(h.slice(5,7),16)];
  }
  function rgba(hex, a) {
    const [r,g,b] = hexRgb(hex);
    return `rgba(${r},${g},${b},${a})`;
  }

  // ── State ──
  let tracks = [], hits = [], beams = [], glow = 0, autoT = 0;
  const trackEl = document.getElementById('track-count');

  // ──────────────────────────────────────────────
  //  DRAW DETECTOR  — rich cross-section view
  // ──────────────────────────────────────────────
  function drawDetector() {
    const ri = (f) => f * R;

    // ── Background radial gradient (space-like) ──
    const bg = ctx.createRadialGradient(cx,cy,0,cx,cy,R*1.3);
    bg.addColorStop(0,   'rgba(2,6,18,0)');
    bg.addColorStop(0.5, 'rgba(2,6,18,0.2)');
    bg.addColorStop(1,   'rgba(0,0,0,0.75)');
    ctx.fillStyle = bg; ctx.fillRect(0,0,W,H);

    // ── TPC bulk — filled annulus with faint drift-field lines ──
    ctx.beginPath();
    ctx.arc(cx,cy,ri(D.tpcOuter),0,Math.PI*2);
    ctx.arc(cx,cy,ri(D.tpcInner),0,Math.PI*2,true);
    ctx.fillStyle = 'rgba(4,18,38,0.55)'; ctx.fill();
    // TPC pad rows (concentric circles, very faint)
    for (let p=0; p<=N_TPC_PAD; p++) {
      const r2 = ri(D.tpcInner) + (ri(D.tpcOuter)-ri(D.tpcInner)) * p/N_TPC_PAD;
      ctx.beginPath(); ctx.arc(cx,cy,r2,0,Math.PI*2);
      ctx.strokeStyle = 'rgba(0,140,220,0.06)'; ctx.lineWidth=0.5; ctx.stroke();
    }
    // TPC radial sectors (36)
    for (let s=0; s<36; s++) {
      const a = Math.PI*2*s/36;
      ctx.beginPath();
      ctx.moveTo(cx+ri(D.tpcInner)*Math.cos(a), cy+ri(D.tpcInner)*Math.sin(a));
      ctx.lineTo(cx+ri(D.tpcOuter)*Math.cos(a), cy+ri(D.tpcOuter)*Math.sin(a));
      ctx.strokeStyle='rgba(0,140,220,0.04)'; ctx.lineWidth=0.5; ctx.stroke();
    }
    // TPC boundary rings
    ctx.beginPath(); ctx.arc(cx,cy,ri(D.tpcOuter),0,Math.PI*2);
    ctx.strokeStyle='rgba(0,170,255,0.25)'; ctx.lineWidth=1.2; ctx.stroke();
    ctx.beginPath(); ctx.arc(cx,cy,ri(D.tpcInner),0,Math.PI*2);
    ctx.strokeStyle='rgba(0,170,255,0.18)'; ctx.lineWidth=1; ctx.stroke();

    // ── ITS — 7 silicon layers ──
    const itsLayerR = [0.067,0.078,0.090,0.108,0.110,0.133,0.148];
    itsLayerR.forEach((f,i) => {
      ctx.beginPath(); ctx.arc(cx,cy,ri(f),0,Math.PI*2);
      ctx.strokeStyle = `rgba(0,210,255,${0.30 - i*0.025})`; ctx.lineWidth=1.2; ctx.stroke();
    });
    // ITS fill
    ctx.beginPath();
    ctx.arc(cx,cy,ri(D.itsOuter),0,Math.PI*2);
    ctx.arc(cx,cy,ri(D.itsInner),0,Math.PI*2,true);
    ctx.fillStyle='rgba(0,30,55,0.40)'; ctx.fill();

    // ── TRD — 18 supermodules, each with 6 layers ──
    const trdR0 = ri(D.trdInner), trdR1 = ri(D.trdOuter);
    const trdLayerColors = [
      'rgba(0,40,20,0.65)','rgba(0,50,25,0.65)','rgba(0,60,30,0.65)',
      'rgba(0,70,35,0.65)','rgba(0,80,40,0.65)','rgba(0,90,45,0.65)',
    ];
    for (let sm=0; sm<N_TRD; sm++) {
      const a0 = Math.PI*2*sm/N_TRD;
      const a1 = Math.PI*2*(sm+1)/N_TRD;
      const amid = (a0+a1)/2;
      // 6 TRD layers per supermodule
      for (let lay=0; lay<6; lay++) {
        const r0 = trdR0 + (trdR1-trdR0)*lay/6;
        const r1 = trdR0 + (trdR1-trdR0)*(lay+1)/6;
        ctx.beginPath();
        ctx.arc(cx,cy,r1,a0,a1);
        ctx.arc(cx,cy,r0,a1,a0,true);
        ctx.closePath();
        ctx.fillStyle = trdLayerColors[lay]; ctx.fill();
        ctx.strokeStyle='rgba(0,180,70,0.12)'; ctx.lineWidth=0.5; ctx.stroke();
      }
      // Supermodule boundary
      ctx.beginPath();
      ctx.moveTo(cx+trdR0*Math.cos(a0), cy+trdR0*Math.sin(a0));
      ctx.lineTo(cx+trdR1*Math.cos(a0), cy+trdR1*Math.sin(a0));
      ctx.strokeStyle='rgba(0,220,80,0.30)'; ctx.lineWidth=0.8; ctx.stroke();
      // SM label (small, every 3rd)
      if (sm % 3 === 0) {
        const lr = (trdR0+trdR1)/2;
        ctx.fillStyle='rgba(0,220,80,0.35)';
        ctx.font=`${Math.max(6, R*0.018)}px monospace`;
        ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.fillText(`SM${sm}`, cx+lr*Math.cos(amid), cy+lr*Math.sin(amid));
      }
    }
    // TRD boundary rings
    ctx.beginPath(); ctx.arc(cx,cy,trdR1,0,Math.PI*2);
    ctx.strokeStyle='rgba(0,220,80,0.50)'; ctx.lineWidth=1.5; ctx.stroke();
    ctx.beginPath(); ctx.arc(cx,cy,trdR0,0,Math.PI*2);
    ctx.strokeStyle='rgba(0,220,80,0.35)'; ctx.lineWidth=1; ctx.stroke();

    // ── TOF — annulus ──
    ctx.beginPath();
    ctx.arc(cx,cy,ri(D.tofOuter),0,Math.PI*2);
    ctx.arc(cx,cy,ri(D.tofInner),0,Math.PI*2,true);
    ctx.fillStyle='rgba(10,10,50,0.55)'; ctx.fill();
    for (let s=0; s<18; s++) {
      const a=Math.PI*2*s/18;
      ctx.beginPath();
      ctx.moveTo(cx+ri(D.tofInner)*Math.cos(a), cy+ri(D.tofInner)*Math.sin(a));
      ctx.lineTo(cx+ri(D.tofOuter)*Math.cos(a), cy+ri(D.tofOuter)*Math.sin(a));
      ctx.strokeStyle='rgba(80,140,255,0.20)'; ctx.lineWidth=0.8; ctx.stroke();
    }
    ctx.beginPath(); ctx.arc(cx,cy,ri(D.tofOuter),0,Math.PI*2);
    ctx.strokeStyle='rgba(80,140,255,0.35)'; ctx.lineWidth=1.2; ctx.stroke();
    ctx.beginPath(); ctx.arc(cx,cy,ri(D.tofInner),0,Math.PI*2);
    ctx.strokeStyle='rgba(80,140,255,0.22)'; ctx.lineWidth=0.8; ctx.stroke();

    // ── EMCal — partial (~120°, bottom half in canvas coords) ──
    const emA0 = Math.PI * 0.82, emA1 = Math.PI * 1.18; // ~65° arc, bottom
    ctx.beginPath();
    ctx.arc(cx,cy,ri(D.emcalOuter),emA0,emA1);
    ctx.arc(cx,cy,ri(D.emcalInner),emA1,emA0,true);
    ctx.closePath();
    ctx.fillStyle='rgba(40,10,40,0.55)'; ctx.fill();
    ctx.strokeStyle='rgba(180,80,220,0.30)'; ctx.lineWidth=1; ctx.stroke();
    // EMCal towers
    const nEmTow = 14;
    for (let t=0; t<=nEmTow; t++) {
      const a = emA0 + (emA1-emA0)*t/nEmTow;
      ctx.beginPath();
      ctx.moveTo(cx+ri(D.emcalInner)*Math.cos(a), cy+ri(D.emcalInner)*Math.sin(a));
      ctx.lineTo(cx+ri(D.emcalOuter)*Math.cos(a), cy+ri(D.emcalOuter)*Math.sin(a));
      ctx.strokeStyle='rgba(180,80,220,0.15)'; ctx.lineWidth=0.6; ctx.stroke();
    }

    // ── Beam pipe ──
    ctx.beginPath(); ctx.arc(cx,cy,ri(D.beamPipe),0,Math.PI*2);
    ctx.strokeStyle='rgba(255,80,80,0.50)'; ctx.lineWidth=2; ctx.stroke();
    ctx.beginPath(); ctx.arc(cx,cy,ri(D.beamPipe)*0.6,0,Math.PI*2);
    ctx.fillStyle='rgba(255,60,60,0.08)'; ctx.fill();
    // Beam axis line
    ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy);
    ctx.strokeStyle='rgba(255,80,80,0.10)'; ctx.lineWidth=1.5; ctx.stroke();
    // IP marker
    ctx.beginPath(); ctx.arc(cx,cy,ri(0.012),0,Math.PI*2);
    ctx.fillStyle='rgba(255,120,120,0.4)'; ctx.fill();
    ctx.strokeStyle='rgba(255,160,160,0.8)'; ctx.lineWidth=1.5; ctx.stroke();

    // ── Detector labels ──
    const labels = [
      { lbl:'ITS',   r: D.itsOuter*0.92,  a:-0.25, col:'rgba(0,210,255,0.55)' },
      { lbl:'TPC',   r: (D.tpcInner+D.tpcOuter)/2, a:-0.18, col:'rgba(0,170,255,0.45)' },
      { lbl:'TRD',   r: (D.trdInner+D.trdOuter)/2, a:-0.20, col:'rgba(0,220,80,0.60)' },
      { lbl:'TOF',   r: (D.tofInner+D.tofOuter)/2, a:-0.22, col:'rgba(80,140,255,0.55)' },
      { lbl:'EMCal', r: (D.emcalInner+D.emcalOuter)/2, a: Math.PI*0.99, col:'rgba(180,80,220,0.55)' },
    ];
    ctx.textBaseline='middle';
    labels.forEach(l => {
      const lx = cx + ri(l.r)*Math.cos(l.a) + 6;
      const ly = cy + ri(l.r)*Math.sin(l.a);
      ctx.font = `bold ${Math.max(10, R*0.032)}px JetBrains Mono, monospace`;
      ctx.textAlign = (l.lbl==='EMCal') ? 'center' : 'left';
      ctx.fillStyle = l.col;
      ctx.fillText(l.lbl, lx, ly);
    });
    ctx.textAlign='left'; ctx.textBaseline='alphabetic';
  }

  // ──────────────────────────────────────────────
  //  PRE-COMPUTE full track arc, then animate draw
  // ──────────────────────────────────────────────
  function makeTrack(angle) {
    const t = Math.random();
    let color, maxR, curv;
    if      (t<0.18) { color=C.electron; maxR=(D.tofOuter+0.05)*R; curv=(Math.random()>0.5?1:-1)*(0.012+Math.random()*0.022); }
    else if (t<0.38) { color=C.pion;     maxR=(D.trdOuter+0.01)*R; curv=(Math.random()>0.5?1:-1)*(0.005+Math.random()*0.015); }
    else if (t<0.52) { color=C.muon;     maxR=(D.emcalInner+0.03)*R; curv=(Math.random()>0.5?1:-1)*0.006; }
    else if (t<0.64) { color=C.kaon;     maxR=(D.trdInner+Math.random()*0.1)*R; curv=(Math.random()>0.5?1:-1)*0.018; }
    else if (t<0.76) { color=C.photon;   maxR=(D.tpcOuter*0.7)*R; curv=0; }
    else             { color=C.proton;   maxR=(D.tpcOuter*0.85)*R; curv=(Math.random()>0.5?1:-1)*(0.02+Math.random()*0.03); }

    // Pre-compute all points along the arc from IP outward
    const pts = [];
    let vx = Math.cos(angle)*3, vy = Math.sin(angle)*3;
    let px = cx, py = cy;
    while (true) {
      pts.push({x:px, y:py});
      if (curv !== 0) {
        const spd = Math.sqrt(vx*vx+vy*vy);
        const a2 = Math.atan2(vy,vx) + curv;
        vx = Math.cos(a2)*spd; vy = Math.sin(a2)*spd;
      }
      px += vx; py += vy;
      const d = Math.sqrt((px-cx)**2+(py-cy)**2);
      if (d >= maxR || pts.length > 800) break;
    }
    return { pts, color, maxR, drawTo: 0, width: 0.8+Math.random()*1.0, angle };
  }

  // ──────────────────────────────────────────────
  //  HITS — lit-up cells in each detector layer
  // ──────────────────────────────────────────────
  function spawnHits(angle, color) {
    const ri = (f) => f * R;

    // ITS pixel hits (7 layers)
    [0.067,0.078,0.090,0.108,0.110,0.133,0.146].forEach(f => {
      if (Math.random()>0.25)
        hits.push({ type:'ITS', r:ri(f), a:angle+(Math.random()-0.5)*0.05, color, age:0, lt:100 });
    });
    // TPC cluster chain
    for (let p=0; p<N_TPC_PAD; p+=3) {
      const fr = D.tpcInner + (D.tpcOuter-D.tpcInner)*p/N_TPC_PAD;
      if (Math.random()>0.3)
        hits.push({ type:'TPC', r:ri(fr), a:angle+(Math.random()-0.5)*0.08, color, age:0, lt:110 });
    }
    // TRD tracklets — one per layer, bright green rectangles
    for (let lay=0; lay<6; lay++) {
      const fr = D.trdInner + (D.trdOuter-D.trdInner)*(lay+0.5)/6;
      hits.push({ type:'TRD', r:ri(fr), a:angle+(Math.random()-0.5)*0.025, color:'#00ff80', age:0, lt:160, lay });
    }
    // TOF hit
    if (Math.random()>0.25)
      hits.push({ type:'TOF', r:ri((D.tofInner+D.tofOuter)/2), a:angle+(Math.random()-0.5)*0.02, color:'#7cb8ff', age:0, lt:200 });
  }

  function drawHits() {
    hits = hits.filter(h => {
      h.age++;
      const fade = Math.max(0, 1-h.age/h.lt);
      const hx = cx + h.r*Math.cos(h.a);
      const hy = cy + h.r*Math.sin(h.a);
      if (h.type==='TRD') {
        // Bright lit-up pad in the TRD layer — rotated rectangle
        const hw=R*0.022, hh=R*0.010;
        ctx.save();
        ctx.translate(hx,hy); ctx.rotate(h.a+Math.PI/2);
        ctx.shadowBlur=8; ctx.shadowColor='#00ff80';
        ctx.fillStyle=`rgba(0,255,128,${fade*0.90})`;
        ctx.fillRect(-hw/2,-hh/2,hw,hh);
        ctx.strokeStyle=`rgba(100,255,160,${fade*0.6})`; ctx.lineWidth=0.5; ctx.strokeRect(-hw/2,-hh/2,hw,hh);
        ctx.restore(); ctx.shadowBlur=0;
      } else if (h.type==='TOF') {
        ctx.beginPath(); ctx.arc(hx,hy,R*0.010,0,Math.PI*2);
        ctx.fillStyle=`rgba(120,190,255,${fade*0.95})`;
        ctx.shadowBlur=10; ctx.shadowColor='#7cb8ff'; ctx.fill(); ctx.shadowBlur=0;
      } else if (h.type==='TPC') {
        ctx.beginPath(); ctx.arc(hx,hy,R*0.005,0,Math.PI*2);
        ctx.fillStyle=rgba(h.color, fade*0.65); ctx.fill();
      } else { // ITS
        const s=R*0.009;
        ctx.fillStyle=rgba(h.color, fade*0.90);
        ctx.shadowBlur=5; ctx.shadowColor=h.color;
        ctx.fillRect(hx-s/2,hy-s/2,s,s); ctx.shadowBlur=0;
      }
      return h.age<h.lt;
    });
  }

  // ──────────────────────────────────────────────
  //  COLLISION
  // ──────────────────────────────────────────────
  function triggerCollision() {
    glow=1; beams=[];
    const n = 24 + Math.floor(Math.random()*16);
    for (let i=0; i<n; i++) {
      const angle = Math.PI*2*i/n + (Math.random()-0.5)*0.35;
      tracks.push(makeTrack(angle));
      spawnHits(angle, rC());
    }
    setTimeout(spawnBeams, 2400);
  }

  function spawnBeams() {
    beams=[];
    for (let i=0; i<3; i++) {
      beams.push({x:-30, y:cy+(i-1)*4, vx:9, trail:[]});
      beams.push({x:W+30, y:cy+(i-1)*4, vx:-9, trail:[]});
    }
  }

  canvas.addEventListener('click', () => triggerCollision());
  canvas.addEventListener('touchend', e=>{ e.preventDefault(); triggerCollision(); }, {passive:false});

  // ──────────────────────────────────────────────
  //  MAIN LOOP
  // ──────────────────────────────────────────────
  function loop() {
    ctx.fillStyle='rgba(2,5,14,0.80)';
    ctx.fillRect(0,0,W,H);

    drawDetector();

    // Collision flash
    if (glow>0) {
      const gr=ctx.createRadialGradient(cx,cy,0,cx,cy,R*0.35);
      gr.addColorStop(0,`rgba(255,245,150,${glow*0.65})`);
      gr.addColorStop(0.4,`rgba(80,160,255,${glow*0.18})`);
      gr.addColorStop(1,'transparent');
      ctx.fillStyle=gr; ctx.fillRect(0,0,W,H);
      glow-=0.025;
    }

    // Beams
    let fired=false;
    beams=beams.filter(b=>{
      b.trail.push({x:b.x,y:b.y});
      if(b.trail.length>14)b.trail.shift();
      b.x+=b.vx;
      const L=beams.filter(bb=>bb.vx>0), Ri=beams.filter(bb=>bb.vx<0);
      if(!fired&&L.length&&Ri.length&&L[0].x+12>=Ri[0].x){fired=true;triggerCollision();return false;}
      ctx.beginPath();
      b.trail.forEach((pt,i)=>i===0?ctx.moveTo(pt.x,pt.y):ctx.lineTo(pt.x,pt.y));
      ctx.lineTo(b.x,b.y);
      ctx.strokeStyle='#ff4466';ctx.lineWidth=1.5;ctx.globalAlpha=0.75;ctx.stroke();ctx.globalAlpha=1;
      ctx.beginPath();ctx.arc(b.x,b.y,3,0,Math.PI*2);
      ctx.fillStyle='#ff4466';ctx.shadowBlur=14;ctx.shadowColor='#ff4466';ctx.fill();ctx.shadowBlur=0;
      return b.x>-50&&b.x<W+50;
    });

    // Hits
    drawHits();

    // Tracks — reveal points progressively
    const REVEAL_SPEED = 6; // points revealed per frame
    tracks=tracks.filter(tr=>{
      tr.drawTo = Math.min(tr.pts.length, tr.drawTo+REVEAL_SPEED);
      const visible = tr.pts.slice(0, tr.drawTo);
      if(visible.length>=2){
        ctx.beginPath();
        visible.forEach((pt,i)=>i===0?ctx.moveTo(pt.x,pt.y):ctx.lineTo(pt.x,pt.y));
        ctx.strokeStyle=tr.color; ctx.lineWidth=tr.width;
        ctx.globalAlpha=0.88; ctx.shadowBlur=4; ctx.shadowColor=tr.color;
        ctx.stroke(); ctx.shadowBlur=0; ctx.globalAlpha=1;
      }
      return tr.drawTo<tr.pts.length || visible.length>0;
    });

    if(trackEl) trackEl.textContent=tracks.length;

    autoT++;
    if(tracks.length===0&&beams.length===0&&autoT>200){spawnBeams();autoT=0;}
    if(tracks.length>0||beams.length>0)autoT=0;

    requestAnimationFrame(loop);
  }

  spawnBeams();
  loop();
})();
</script>

