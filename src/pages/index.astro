---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
  <Header />
  <main>
    <div class="hero">
      <h1>👋 Hi, I'm Madhva</h1>
      <p class="tagline">
        MSc Physics Student · ALICE Experiment at CERN · Münster, Germany
      </p>
    </div>

    <section>
      <h2>About Me</h2>
      <p>
        I'm a Master's student in Physics working on my thesis focused on 
        <strong>electron-pion separation</strong> using the Transition Radiation 
        Detector (TRD) in the ALICE experiment at CERN. I work with real Run 3 
        data using machine learning techniques including Boosted Decision Trees 
        for particle identification.
      </p>
    </section>

    <section>
      <h2>🔬 Current Research</h2>
      <div class="card">
        <h3>TRD Electron-Pion Separation — ALICE/CERN</h3>
        <p>
          Developing an analysis pipeline for particle identification using 
          the ALICE Transition Radiation Detector. Working with O2Physics, 
          ROOT framework, and real Run 3 experimental data on CERN lxplus servers.
        </p>
        <div class="tags">
          <span>ROOT</span>
          <span>O2Physics</span>
          <span>C++</span>
          <span>BDT / ML</span>
          <span>CERN lxplus</span>
          <span>Run 3 Data</span>
        </div>
        <a href="https://github.com/madhva8/alice-trd-analysis" 
           target="_blank" class="btn">
          View on GitHub →
        </a>
      </div>
    </section>

    <section>
      <h2>🔗 Find Me</h2>
      <div class="link-row">
        <a href="https://github.com/madhva8" target="_blank">GitHub</a>
        <a href="mailto:madhva.fakare@cern.ch">madhva.fakare@cern.ch</a>
        <a href="/blog">Research Blog</a>
        <a href="/assistant">AI Assistant</a>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>

<style>
  main {
    max-width: 750px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: #666;
    font-size: 1.1rem;
  }

  section {
    margin: 2.5rem 0;
  }

  h2 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid #eee;
    padding-bottom: 0.5rem;
  }

  p {
    color: #444;
    line-height: 1.7;
  }

  .card {
    background: #f9f9f9;
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid #eee;
  }

  .card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }

  .card p {
    margin-bottom: 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1rem;
  }

  .tags span {
    background: #0070f3;
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
  }

  .btn {
    display: inline-block;
    background: #0070f3;
    color: white;
    padding: 8px 16px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.9rem;
  }

  .btn:hover { background: #005bb5; }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .link-row a {
    background: #f0f0f0;
    padding: 8px 16px;
    border-radius: 8px;
    text-decoration: none;
    color: #333;
    font-size: 0.95rem;
  }

  .link-row a:hover { background: #ddd; }
</style>