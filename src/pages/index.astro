---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
  <Header />
  <main>

    <!-- HERO: canvas FIRST in HTML so it's on top on mobile -->
    <section class="hero">
      <div class="hero-visual">
        <canvas id="detector" width="320" height="320"></canvas>
        <div class="detector-label">ALICE Event Display · tap to collide</div>
      </div>
      <div class="hero-inner">
        <div class="badge">MSc Physics · ALICE/CERN · Münster</div>
        <h1>Hi, I'm<br/><span class="name-gradient">Madhva Fakare</span></h1>
        <p class="tagline">Particle physicist building ML pipelines for electron-pion separation using the TRD at CERN.</p>
        <div class="hero-actions">
          <a href="/assistant" class="btn-primary">Try Physics AI →</a>
          <a href="https://github.com/madhva8" target="_blank" class="btn-secondary">GitHub</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-label">Current Research</div>
      <h2>TRD Electron-Pion Separation</h2>
      <div class="research-card">
        <div class="research-header">
          <div class="research-icon">🔬</div>
          <div class="research-meta">
            <div class="research-title">ALICE Experiment · CERN</div>
            <div class="research-sub">Run 3 Data Analysis · lxplus servers</div>
          </div>
        </div>
        <p class="research-desc">Developing an analysis pipeline for particle identification using the ALICE Transition Radiation Detector. Working with O2Physics, ROOT framework, and real Run 3 experimental data.</p>
        <div class="tags">
          <span>ROOT</span><span>O2Physics</span><span>C++</span>
          <span>BDT / ML</span><span>CERN lxplus</span><span>Run 3 Data</span>
        </div>
        <a href="https://github.com/madhva8/alice-trd-analysis" target="_blank" class="research-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          View on GitHub →
        </a>
      </div>
    </section>

    <section class="section">
      <div class="section-label">About Me</div>
      <h2>Background</h2>
      <p class="about-text">I'm a Master's student in Physics working on my thesis focused on <strong>electron-pion separation</strong> using the Transition Radiation Detector (TRD) in the ALICE experiment at CERN. I work with real Run 3 data using machine learning techniques including Boosted Decision Trees for particle identification.</p>
    </section>

    <section class="section">
      <div class="section-label">Connect</div>
      <h2>Find Me</h2>
      <div class="link-grid">
        <a href="https://github.com/madhva8" target="_blank" class="link-card">
          <span class="link-icon"><svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg></span>
          <span class="link-label">GitHub</span><span class="link-arrow">→</span>
        </a>
        <a href="mailto:madhva.fakare@cern.ch" class="link-card">
          <span class="link-icon">✉</span><span class="link-label">CERN Email</span><span class="link-arrow">→</span>
        </a>
        <a href="/blog" class="link-card">
          <span class="link-icon">📝</span><span class="link-label">Research Blog</span><span class="link-arrow">→</span>
        </a>
        <a href="/assistant" class="link-card highlight">
          <span class="link-icon">🔬</span><span class="link-label">Physics AI Assistant</span><span class="link-arrow">→</span>
        </a>
      </div>
    </section>

  </main>
  <Footer />
</body>
</html>

<script is:inline>
(function() {
  const canvas = document.getElementById('detector');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const cx = W/2, cy = H/2;

  const COLORS = {
    electron: '#00d4ff', pion: '#ff6b35', photon: '#fff700',
    muon: '#b44fff', proton: '#ff4466', neutron: '#44ff88', gluon: '#ff8800',
  };
  const colorList = Object.values(COLORS);
  function rndColor() { return colorList[Math.floor(Math.random() * colorList.length)]; }

  let particles = [], beams = [], jets = [], glowPulse = 0, autoTimer = 0;

  canvas.addEventListener('click', function(e) {
    const r = canvas.getBoundingClientRect();
    triggerCollision((e.clientX - r.left) * W / r.width, (e.clientY - r.top) * H / r.height);
  });
  canvas.addEventListener('touchend', function(e) {
    e.preventDefault();
    const r = canvas.getBoundingClientRect();
    const t = e.changedTouches[0];
    triggerCollision((t.clientX - r.left) * W / r.width, (t.clientY - r.top) * H / r.height);
  }, { passive: false });

  function spawnBeams() {
    beams = [];
    for (let i = 0; i < 3; i++) {
      beams.push({ x: -20, y: cy+(i-1)*5, vx: 7, vy: 0, color: COLORS.proton, trail: [] });
      beams.push({ x: W+20, y: cy+(i-1)*5, vx: -7, vy: 0, color: COLORS.proton, trail: [] });
    }
  }

  function triggerCollision(x, y) {
    const n = 20 + Math.floor(Math.random() * 14);
    for (let i = 0; i < n; i++) {
      const angle = (Math.PI*2*i/n) + (Math.random()-0.5)*0.5;
      const speed = 1.2 + Math.random()*3.5;
      const t = Math.random();
      let color, curved, lifetime;
      if (t<0.2)       { color=COLORS.electron; curved=true;  lifetime=130; }
      else if (t<0.4)  { color=COLORS.pion;     curved=false; lifetime=90;  }
      else if (t<0.55) { color=COLORS.photon;   curved=false; lifetime=55;  }
      else if (t<0.65) { color=COLORS.muon;     curved=true;  lifetime=180; }
      else if (t<0.75) { color=COLORS.gluon;    curved=false; lifetime=45;  }
      else             { color=COLORS.neutron;  curved=false; lifetime=75;  }
      particles.push({ x, y, vx: Math.cos(angle)*speed, vy: Math.sin(angle)*speed,
        color, alpha:1, lifetime, age:0, curved, curvature:(Math.random()-0.5)*0.07,
        trail:[], width:0.8+Math.random()*1.4, decayed:false, decayAt:35+Math.random()*55 });
    }
    for (let j=0; j<2+Math.floor(Math.random()*3); j++)
      jets.push({ x, y, angle:Math.random()*Math.PI*2, age:0, lifetime:75, color:rndColor() });
    beams = []; glowPulse = 1;
    setTimeout(spawnBeams, 1800);
  }

  function drawDetector() {
    [[40,'ITS'],[72,'TPC'],[105,'TRD'],[130,'TOF'],[148,'']].forEach(([r,lbl],i) => {
      ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2);
      ctx.strokeStyle = i===2 ? 'rgba(0,212,255,0.22)' : 'rgba(0,212,255,0.09)';
      ctx.lineWidth = i===2 ? 2 : 1; ctx.setLineDash(i===2?[]:[3,8]); ctx.stroke(); ctx.setLineDash([]);
      if (lbl) { ctx.fillStyle='rgba(0,212,255,0.3)'; ctx.font='8px monospace'; ctx.fillText(lbl,cx+r+3,cy-3); }
    });
    for (let s=0; s<18; s++) {
      const a = Math.PI*2*s/18;
      ctx.beginPath(); ctx.moveTo(cx+105*Math.cos(a),cy+105*Math.sin(a)); ctx.lineTo(cx+130*Math.cos(a),cy+130*Math.sin(a));
      ctx.strokeStyle='rgba(0,212,255,0.1)'; ctx.lineWidth=1; ctx.stroke();
    }
    ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy);
    ctx.strokeStyle='rgba(255,80,80,0.12)'; ctx.lineWidth=3; ctx.stroke();
    ctx.beginPath(); ctx.arc(cx,cy,6,0,Math.PI*2);
    ctx.fillStyle='rgba(255,80,80,0.18)'; ctx.fill();
    ctx.strokeStyle='rgba(255,80,80,0.4)'; ctx.lineWidth=1; ctx.stroke();
  }

  function loop() {
    ctx.fillStyle='#07070d'; ctx.fillRect(0,0,W,H);
    drawDetector();
    if (glowPulse>0) {
      const r=(1-glowPulse)*160, g=ctx.createRadialGradient(cx,cy,0,cx,cy,r);
      g.addColorStop(0,'rgba(255,255,180,'+(glowPulse*0.55)+')');
      g.addColorStop(0.4,'rgba(80,180,255,'+(glowPulse*0.25)+')');
      g.addColorStop(1,'transparent');
      ctx.fillStyle=g; ctx.fillRect(0,0,W,H); glowPulse-=0.035;
    }
    let triggered=false;
    beams = beams.filter(b => {
      b.trail.push({x:b.x,y:b.y}); if(b.trail.length>14)b.trail.shift(); b.x+=b.vx; b.y+=b.vy;
      const left=beams.filter(bb=>bb.vx>0), right=beams.filter(bb=>bb.vx<0);
      if(!triggered&&left.length&&right.length&&left[0].x+10>=right[0].x) { triggered=true; triggerCollision(cx,cy); return false; }
      ctx.beginPath(); b.trail.forEach((pt,i)=>{i===0?ctx.moveTo(pt.x,pt.y):ctx.lineTo(pt.x,pt.y);}); ctx.lineTo(b.x,b.y);
      ctx.strokeStyle=b.color; ctx.lineWidth=2; ctx.globalAlpha=0.85; ctx.stroke(); ctx.globalAlpha=1;
      ctx.beginPath(); ctx.arc(b.x,b.y,3.5,0,Math.PI*2);
      ctx.fillStyle=b.color; ctx.shadowBlur=12; ctx.shadowColor=b.color; ctx.fill(); ctx.shadowBlur=0;
      return b.x>-30&&b.x<W+30;
    });
    jets = jets.filter(j => {
      const t=j.age/j.lifetime;
      for(let i=0;i<10;i++){
        const a=j.angle+(i/10-0.5)*0.35, len=t*110*(0.5+Math.random()*0.5);
        ctx.beginPath(); ctx.moveTo(j.x,j.y); ctx.lineTo(j.x+Math.cos(a)*len,j.y+Math.sin(a)*len);
        ctx.strokeStyle=j.color; ctx.globalAlpha=(1-t)*0.35; ctx.lineWidth=0.7; ctx.stroke(); ctx.globalAlpha=1;
      }
      j.age++; return j.age<j.lifetime;
    });
    particles = particles.filter(p => {
      p.age++; p.trail.push({x:p.x,y:p.y}); if(p.trail.length>35)p.trail.shift();
      if(p.curved){const a=Math.atan2(p.vy,p.vx)+p.curvature,s=Math.sqrt(p.vx*p.vx+p.vy*p.vy);p.vx=Math.cos(a)*s;p.vy=Math.sin(a)*s;}
      if(!p.decayed&&p.age>p.decayAt&&Math.random()<0.04){
        p.decayed=true;
        for(let d=0;d<2;d++){const a=Math.atan2(p.vy,p.vx)+(Math.random()-0.5)*1.4,s=Math.sqrt(p.vx*p.vx+p.vy*p.vy)*0.55;
          particles.push({x:p.x,y:p.y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,color:rndColor(),alpha:0.8,lifetime:55,age:0,curved:false,curvature:0,trail:[],width:0.6,decayed:true,decayAt:9999});}
      }
      p.x+=p.vx; p.y+=p.vy; p.alpha=Math.max(0,1-p.age/p.lifetime);
      if(p.trail.length>=2){
        ctx.beginPath(); p.trail.forEach((pt,i)=>{i===0?ctx.moveTo(pt.x,pt.y):ctx.lineTo(pt.x,pt.y);}); ctx.lineTo(p.x,p.y);
        ctx.strokeStyle=p.color; ctx.lineWidth=p.width; ctx.globalAlpha=p.alpha; ctx.shadowBlur=5; ctx.shadowColor=p.color;
        ctx.stroke(); ctx.shadowBlur=0; ctx.globalAlpha=1;
      }
      return p.age<p.lifetime&&p.alpha>0.01;
    });
    ctx.fillStyle='rgba(0,212,255,0.35)'; ctx.font='8px monospace';
    ctx.fillText('ALICE · Pb+Pb · \u221As=5.5 TeV',8,14);
    ctx.fillText('N\u2080 tracks: '+particles.length,8,24);
    autoTimer++;
    if(particles.length===0&&beams.length===0){
      ctx.fillStyle='rgba(0,212,255,0.3)'; ctx.font='9px monospace'; ctx.textAlign='center';
      ctx.fillText('tap to collide',cx,H-10); ctx.textAlign='left';
      if(autoTimer>200){spawnBeams();autoTimer=0;}
    } else { autoTimer=0; }
    requestAnimationFrame(loop);
  }

  spawnBeams(); loop();
})();
</script>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  body { font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif; background: #fafafa; color: #111; margin: 0; overflow-x: hidden; }
  main { max-width: 900px; margin: 0 auto; padding: 0 1rem 4rem; }

  /* ── HERO: mobile-first, stacks top-to-bottom ── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 0;
    text-align: center;
  }
  /* On desktop: side by side, text on left */
  @media (min-width: 700px) {
    .hero {
      flex-direction: row;
      text-align: left;
      gap: 3rem;
      padding: 3.5rem 0 3rem;
    }
    .hero-visual { order: 2; flex-shrink: 0; }
    .hero-inner { order: 1; flex: 1; }
    .hero-actions { justify-content: flex-start; }
    .badge { margin-left: 0; }
  }

  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }
  @media (min-width: 700px) {
    .hero-visual { width: auto; }
  }

  canvas {
    width: min(280px, calc(100vw - 2rem));
    height: min(280px, calc(100vw - 2rem));
    border-radius: 16px;
    border: 1px solid rgba(0,212,255,0.2);
    box-shadow: 0 0 40px rgba(0,100,200,0.1);
    cursor: crosshair;
    display: block;
  }
  @media (min-width: 700px) {
    canvas { width: 300px; height: 300px; }
  }

  .detector-label { font-size: 0.66rem; color: #999; font-family: 'DM Mono', monospace; }

  .hero-inner { width: 100%; }
  .badge {
    display: inline-flex;
    background: #e8f0fe; color: #0070f3;
    font-size: 0.74rem; font-weight: 600;
    padding: 5px 12px; border-radius: 20px;
    margin-bottom: 1rem;
  }
  h1 { font-size: clamp(1.9rem, 5vw, 2.8rem); font-weight: 800; line-height: 1.15; margin: 0 0 0.9rem; letter-spacing: -0.02em; color: #0a0a0a; }
  .name-gradient { background: linear-gradient(135deg,#0070f3,#7928ca); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .tagline { font-size: 0.95rem; color: #555; line-height: 1.65; margin: 0 0 1.5rem; }
  .hero-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
  .btn-primary { display: inline-block; background: linear-gradient(135deg,#0070f3,#7928ca); color: white; padding: 11px 22px; border-radius: 10px; text-decoration: none; font-size: 0.9rem; font-weight: 600; transition: all 0.2s; box-shadow: 0 4px 16px rgba(0,112,243,0.28); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(0,112,243,0.4); }
  .btn-secondary { display: inline-block; background: white; color: #333; padding: 11px 22px; border-radius: 10px; text-decoration: none; font-size: 0.9rem; font-weight: 600; border: 1px solid #ddd; transition: all 0.2s; }
  .btn-secondary:hover { background: #f5f5f5; }

  /* ── SECTIONS ── */
  .section { margin: 2.5rem 0; padding-top: 2rem; border-top: 1px solid #ebebeb; }
  .section-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #0070f3; margin-bottom: 6px; }
  h2 { font-size: 1.35rem; font-weight: 700; color: #0a0a0a; margin: 0 0 1.2rem; }

  .research-card { background: white; border: 1px solid #e8e8e8; border-radius: 16px; padding: 1.25rem; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
  .research-header { display: flex; align-items: center; gap: 12px; margin-bottom: 1rem; }
  .research-icon { font-size: 1.6rem; line-height: 1; flex-shrink: 0; }
  .research-title { font-size: 0.92rem; font-weight: 700; color: #111; }
  .research-sub { font-size: 0.75rem; color: #888; margin-top: 2px; }
  .research-desc { font-size: 0.9rem; color: #555; line-height: 1.7; margin: 0 0 1rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 1rem; }
  .tags span { background: #f0f4ff; color: #0050cc; padding: 4px 10px; border-radius: 20px; font-size: 0.74rem; font-weight: 500; }
  .research-link { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: #111; color: white; border-radius: 8px; text-decoration: none; font-size: 0.82rem; font-weight: 500; transition: all 0.15s; }
  .research-link:hover { background: #333; }

  .about-text { font-size: 0.95rem; color: #444; line-height: 1.75; }
  .about-text strong { color: #111; }

  .link-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  @media (max-width: 480px) { .link-grid { grid-template-columns: 1fr; } }
  .link-card { display: flex; align-items: center; gap: 10px; padding: 14px; background: white; border: 1px solid #e8e8e8; border-radius: 12px; text-decoration: none; color: #333; font-size: 0.87rem; font-weight: 500; transition: all 0.15s; }
  .link-card:hover { border-color: #0070f3; color: #0070f3; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,112,243,0.1); }
  .link-card.highlight { background: linear-gradient(135deg,#f0f4ff,#f5f0ff); border-color: #c8d8ff; }
  .link-card.highlight:hover { border-color: #7928ca; color: #7928ca; }
  .link-icon { font-size: 1.1rem; flex-shrink: 0; display: flex; }
  .link-label { flex: 1; }
  .link-arrow { color: #bbb; font-size: 0.9rem; }
</style>
