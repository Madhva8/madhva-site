---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Fixed particle canvas background -->
  <canvas id="bg-canvas"></canvas>

  <!-- Dark header overlay -->
  <Header />

  <main>

    <!-- HERO: full-screen, content over canvas -->
    <section class="hero">
      <div class="hero-content">
        <div class="badge">
          <span class="badge-dot"></span>
          ALICE Experiment · CERN · Münster
        </div>
        <h1>
          Hi, I'm<br>
          <span class="name">Madhva Fakare</span>
        </h1>
        <p class="tagline">
          MSc Physics student building machine learning pipelines<br class="br-desktop">
          for electron-pion separation using the TRD at CERN.
        </p>
        <div class="hero-actions">
          <a href="/assistant" class="btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
            Physics AI Assistant
          </a>
          <a href="https://github.com/madhva8" target="_blank" class="btn-secondary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
        </div>
        <div class="hero-hint">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
          Click anywhere to trigger a particle collision
        </div>
      </div>

      <!-- HUD overlay: detector info -->
      <div class="detector-hud">
        <div class="hud-item">
          <span class="hud-label">Experiment</span>
          <span class="hud-value">ALICE · LHC</span>
        </div>
        <div class="hud-item">
          <span class="hud-label">Collision</span>
          <span class="hud-value">Pb+Pb</span>
        </div>
        <div class="hud-item">
          <span class="hud-label">Energy</span>
          <span class="hud-value">√s = 5.5 TeV</span>
        </div>
        <div class="hud-item">
          <span class="hud-label">Tracks</span>
          <span class="hud-value" id="track-count">0</span>
        </div>
      </div>

      <div class="scroll-indicator">
        <span>Scroll</span>
        <div class="scroll-arrow"></div>
      </div>
    </section>

    <!-- CONTENT SECTIONS on white background -->
    <div class="content-area">

      <section class="section">
        <div class="section-inner">
          <div class="section-label">Current Research</div>
          <h2>TRD Electron-Pion Separation</h2>
          <div class="research-grid">
            <div class="research-card main-card">
              <div class="card-top">
                <div class="card-icon">🔬</div>
                <div>
                  <div class="card-title">ALICE Experiment · CERN</div>
                  <div class="card-sub">Run 3 Data Analysis · lxplus servers</div>
                </div>
                <a href="https://github.com/madhva8/alice-trd-analysis" target="_blank" class="github-btn">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                  Repo
                </a>
              </div>
              <p class="card-desc">Developing an analysis pipeline for particle identification using the ALICE Transition Radiation Detector. Working with O2Physics, ROOT framework, and real Run 3 experimental data on CERN lxplus servers.</p>
              <div class="tags">
                <span>ROOT</span><span>O2Physics</span><span>C++</span>
                <span>BDT / ML</span><span>CERN lxplus</span><span>Run 3</span>
              </div>
            </div>
            <div class="stat-cards">
              <div class="stat-card">
                <div class="stat-num">Run 3</div>
                <div class="stat-label">ALICE Data</div>
              </div>
              <div class="stat-card">
                <div class="stat-num">TRD</div>
                <div class="stat-label">Detector</div>
              </div>
              <div class="stat-card">
                <div class="stat-num">BDT</div>
                <div class="stat-label">ML Method</div>
              </div>
              <div class="stat-card">
                <div class="stat-num">e/π</div>
                <div class="stat-label">Separation</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section alt">
        <div class="section-inner">
          <div class="section-label">About Me</div>
          <h2>Background</h2>
          <div class="about-grid">
            <p class="about-text">I'm a Master's student in Physics working on my thesis focused on <strong>electron-pion separation</strong> using the Transition Radiation Detector (TRD) in the ALICE experiment at CERN. I work with real Run 3 data using machine learning techniques including Boosted Decision Trees for particle identification.</p>
            <div class="about-pills">
              <div class="pill">📍 Münster, Germany</div>
              <div class="pill">🎓 MSc Physics</div>
              <div class="pill">⚛ ALICE/CERN</div>
              <div class="pill">💻 O2Physics · ROOT</div>
              <div class="pill">🤖 ML / BDT</div>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-inner">
          <div class="section-label">Connect</div>
          <h2>Find Me</h2>
          <div class="link-grid">
            <a href="https://github.com/madhva8" target="_blank" class="link-card">
              <div class="link-icon-wrap">
                <svg viewBox="0 0 16 16" width="22" height="22" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              </div>
              <div class="link-info">
                <div class="link-title">GitHub</div>
                <div class="link-sub">alice-trd-analysis</div>
              </div>
              <span class="link-arr">→</span>
            </a>
            <a href="mailto:madhva.fakare@cern.ch" class="link-card">
              <div class="link-icon-wrap">📧</div>
              <div class="link-info">
                <div class="link-title">Email</div>
                <div class="link-sub">madhva.fakare@cern.ch</div>
              </div>
              <span class="link-arr">→</span>
            </a>
            <a href="/blog" class="link-card">
              <div class="link-icon-wrap">📝</div>
              <div class="link-info">
                <div class="link-title">Research Blog</div>
                <div class="link-sub">Notes & updates</div>
              </div>
              <span class="link-arr">→</span>
            </a>
            <a href="/assistant" class="link-card featured">
              <div class="link-icon-wrap">⚛</div>
              <div class="link-info">
                <div class="link-title">Physics AI Assistant</div>
                <div class="link-sub">Powered by Gemini & DeepSeek</div>
              </div>
              <span class="link-arr">→</span>
            </a>
          </div>
        </div>
      </section>

    </div><!-- /content-area -->
  </main>

  <Footer />

</body>
</html>

<script is:inline>
(function () {
  // ── CANVAS SETUP ──
  const canvas = document.getElementById('bg-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, cx, cy;

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W / 2; cy = H / 2;
  }
  resize();
  window.addEventListener('resize', resize);

  // ── COLORS ──
  const C = {
    electron: '#00d4ff', pion: '#ff6b35', photon: '#ffe566',
    muon: '#c084fc', proton: '#ff4466', neutron: '#4ade80', gluon: '#fb923c',
  };
  const cList = Object.values(C);
  const rndC = () => cList[Math.floor(Math.random() * cList.length)];

  // ── STATE ──
  let particles = [], beams = [], jets = [], glowPulse = 0, glowX = 0, glowY = 0;
  let autoTimer = 0;
  const trackEl = document.getElementById('track-count');

  // ── COLLISION ──
  function triggerCollision(x, y) {
    glowX = x; glowY = y; glowPulse = 1;
    const n = 28 + Math.floor(Math.random() * 18);
    for (let i = 0; i < n; i++) {
      const angle = (Math.PI * 2 * i / n) + (Math.random() - 0.5) * 0.5;
      const speed = 1.5 + Math.random() * 5;
      const t = Math.random();
      let color, curved, lifetime;
      if      (t < 0.20) { color = C.electron; curved = true;  lifetime = 160; }
      else if (t < 0.40) { color = C.pion;     curved = false; lifetime = 110; }
      else if (t < 0.55) { color = C.photon;   curved = false; lifetime = 70;  }
      else if (t < 0.65) { color = C.muon;     curved = true;  lifetime = 220; }
      else if (t < 0.75) { color = C.gluon;    curved = false; lifetime = 55;  }
      else               { color = C.neutron;  curved = false; lifetime = 90;  }
      particles.push({
        x, y, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
        color, alpha: 1, lifetime, age: 0, curved,
        curvature: (Math.random() - 0.5) * 0.055,
        trail: [], width: 0.8 + Math.random() * 1.6,
        decayed: false, decayAt: 40 + Math.random() * 70,
      });
    }
    for (let j = 0; j < 2 + Math.floor(Math.random() * 4); j++)
      jets.push({ x, y, angle: Math.random() * Math.PI * 2, age: 0, lifetime: 90, color: rndC() });
    beams = [];
    setTimeout(spawnBeams, 2000);
  }

  // ── BEAMS ──
  function spawnBeams() {
    beams = [];
    for (let i = 0; i < 4; i++) {
      beams.push({ x: -30, y: cy + (i - 1.5) * 5, vx: 9, vy: 0, color: C.proton, trail: [] });
      beams.push({ x: W + 30, y: cy + (i - 1.5) * 5, vx: -9, vy: 0, color: C.proton, trail: [] });
    }
  }

  // ── INPUT ──
  function handleClick(px, py) { triggerCollision(px, py); }
  canvas.addEventListener('click', e => handleClick(e.clientX, e.clientY));
  canvas.addEventListener('touchend', e => {
    e.preventDefault();
    const t = e.changedTouches[0];
    handleClick(t.clientX, t.clientY);
  }, { passive: false });

  // ── DRAW DETECTOR RINGS (scaled to viewport) ──
  function drawDetector() {
    const scale = Math.min(W, H) * 0.38;
    const rings = [
      { r: 0.18, label: 'ITS', dash: [3, 9], w: 1,   alpha: 0.12 },
      { r: 0.36, label: 'TPC', dash: [3, 9], w: 1,   alpha: 0.10 },
      { r: 0.56, label: 'TRD', dash: [],     w: 1.5, alpha: 0.20 },
      { r: 0.72, label: 'TOF', dash: [3, 9], w: 1,   alpha: 0.08 },
      { r: 0.90, label: '',    dash: [2,12], w: 0.8, alpha: 0.05 },
    ];
    rings.forEach(({r, label, dash, w, alpha}) => {
      ctx.beginPath();
      ctx.arc(cx, cy, r * scale, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(0,212,255,${alpha})`;
      ctx.lineWidth = w;
      ctx.setLineDash(dash);
      ctx.stroke();
      ctx.setLineDash([]);
      if (label) {
        ctx.fillStyle = 'rgba(0,212,255,0.28)';
        ctx.font = '10px JetBrains Mono, monospace';
        ctx.fillText(label, cx + r * scale + 5, cy - 4);
      }
    });
    // TRD sectors
    for (let s = 0; s < 18; s++) {
      const a = Math.PI * 2 * s / 18;
      ctx.beginPath();
      ctx.moveTo(cx + 0.56 * scale * Math.cos(a), cy + 0.56 * scale * Math.sin(a));
      ctx.lineTo(cx + 0.72 * scale * Math.cos(a), cy + 0.72 * scale * Math.sin(a));
      ctx.strokeStyle = 'rgba(0,212,255,0.08)';
      ctx.lineWidth = 1;
      ctx.stroke();
    }
    // Beam pipe
    ctx.beginPath(); ctx.moveTo(0, cy); ctx.lineTo(W, cy);
    ctx.strokeStyle = 'rgba(255,80,80,0.1)'; ctx.lineWidth = 3; ctx.stroke();
    // Interaction point
    ctx.beginPath(); ctx.arc(cx, cy, 6, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(255,80,80,0.15)'; ctx.fill();
    ctx.strokeStyle = 'rgba(255,80,80,0.5)'; ctx.lineWidth = 1.5; ctx.stroke();
  }

  // ── MAIN LOOP ──
  function loop() {
    // Dark background with slight trail effect
    ctx.fillStyle = 'rgba(4,6,14,0.88)';
    ctx.fillRect(0, 0, W, H);

    drawDetector();

    // Collision glow
    if (glowPulse > 0) {
      const maxR = Math.min(W, H) * 0.7;
      const r = (1 - glowPulse) * maxR;
      const g = ctx.createRadialGradient(glowX, glowY, 0, glowX, glowY, r);
      g.addColorStop(0,   `rgba(255,240,160,${glowPulse * 0.5})`);
      g.addColorStop(0.3, `rgba(100,180,255,${glowPulse * 0.2})`);
      g.addColorStop(1,   'transparent');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, W, H);
      glowPulse -= 0.028;
      if (glowPulse < 0) glowPulse = 0;
    }

    // Beams
    let triggered = false;
    beams = beams.filter(b => {
      b.trail.push({ x: b.x, y: b.y });
      if (b.trail.length > 16) b.trail.shift();
      b.x += b.vx; b.y += b.vy;
      const left = beams.filter(bb => bb.vx > 0);
      const right = beams.filter(bb => bb.vx < 0);
      if (!triggered && left.length && right.length && left[0].x + 12 >= right[0].x) {
        triggered = true;
        triggerCollision(cx, cy);
        return false;
      }
      ctx.beginPath();
      b.trail.forEach((pt, i) => i === 0 ? ctx.moveTo(pt.x, pt.y) : ctx.lineTo(pt.x, pt.y));
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = b.color; ctx.lineWidth = 2; ctx.globalAlpha = 0.8; ctx.stroke(); ctx.globalAlpha = 1;
      ctx.beginPath(); ctx.arc(b.x, b.y, 4, 0, Math.PI * 2);
      ctx.fillStyle = b.color; ctx.shadowBlur = 14; ctx.shadowColor = b.color; ctx.fill(); ctx.shadowBlur = 0;
      return b.x > -50 && b.x < W + 50;
    });

    // Jets
    jets = jets.filter(j => {
      const t = j.age / j.lifetime;
      const len = t * Math.min(W, H) * 0.35;
      for (let i = 0; i < 12; i++) {
        const a = j.angle + (i / 12 - 0.5) * 0.4;
        ctx.beginPath();
        ctx.moveTo(j.x, j.y);
        ctx.lineTo(j.x + Math.cos(a) * len * (0.4 + Math.random() * 0.6), j.y + Math.sin(a) * len * (0.4 + Math.random() * 0.6));
        ctx.strokeStyle = j.color; ctx.globalAlpha = (1 - t) * 0.3; ctx.lineWidth = 0.8; ctx.stroke(); ctx.globalAlpha = 1;
      }
      j.age++;
      return j.age < j.lifetime;
    });

    // Particle tracks
    particles = particles.filter(p => {
      p.age++;
      p.trail.push({ x: p.x, y: p.y });
      if (p.trail.length > 40) p.trail.shift();
      if (p.curved) {
        const a = Math.atan2(p.vy, p.vx) + p.curvature;
        const s = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        p.vx = Math.cos(a) * s; p.vy = Math.sin(a) * s;
      }
      if (!p.decayed && p.age > p.decayAt && Math.random() < 0.035) {
        p.decayed = true;
        for (let d = 0; d < 2; d++) {
          const a = Math.atan2(p.vy, p.vx) + (Math.random() - 0.5) * 1.5;
          const s = Math.sqrt(p.vx * p.vx + p.vy * p.vy) * 0.6;
          particles.push({ x: p.x, y: p.y, vx: Math.cos(a) * s, vy: Math.sin(a) * s, color: rndC(), alpha: 0.7, lifetime: 70, age: 0, curved: false, curvature: 0, trail: [], width: 0.7, decayed: true, decayAt: 9999 });
        }
      }
      p.x += p.vx; p.y += p.vy;
      p.alpha = Math.max(0, 1 - p.age / p.lifetime);
      if (p.trail.length >= 2) {
        ctx.beginPath();
        p.trail.forEach((pt, i) => i === 0 ? ctx.moveTo(pt.x, pt.y) : ctx.lineTo(pt.x, pt.y));
        ctx.lineTo(p.x, p.y);
        ctx.strokeStyle = p.color; ctx.lineWidth = p.width;
        ctx.globalAlpha = p.alpha; ctx.shadowBlur = 4; ctx.shadowColor = p.color;
        ctx.stroke(); ctx.shadowBlur = 0; ctx.globalAlpha = 1;
      }
      return p.age < p.lifetime && p.alpha > 0.01;
    });

    // Update HUD
    if (trackEl) trackEl.textContent = particles.length;

    // Auto-fire
    autoTimer++;
    if (particles.length === 0 && beams.length === 0 && autoTimer > 180) {
      spawnBeams(); autoTimer = 0;
    }
    if (particles.length > 0 || beams.length > 0) autoTimer = 0;

    requestAnimationFrame(loop);
  }

  spawnBeams();
  loop();
})();
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    --accent: #00d4ff;
    --accent2: #6366f1;
    --white: #ffffff;
  }

  html, body {
    margin: 0; padding: 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #04060e;
    color: #111;
    overflow-x: hidden;
  }

  /* Canvas fills full viewport, fixed behind everything */
  #bg-canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    z-index: 0;
    pointer-events: auto;
  }

  /* Header sits on top of canvas */
  header {
    position: relative;
    z-index: 20;
    background: rgba(4,6,14,0.7) !important;
    backdrop-filter: blur(16px) !important;
    -webkit-backdrop-filter: blur(16px) !important;
    border-bottom: 1px solid rgba(255,255,255,0.06) !important;
    box-shadow: none !important;
  }
  header :global(a),
  header :global(.brand-name),
  header :global(.logo-text) {
    color: rgba(255,255,255,0.9) !important;
  }
  header :global(a:hover) {
    color: #fff !important;
    background: rgba(255,255,255,0.08) !important;
  }
  header :global(a.active) {
    color: var(--accent) !important;
    background: rgba(0,212,255,0.1) !important;
  }
  header :global(.hamburger span) {
    background: rgba(255,255,255,0.8) !important;
  }
  header :global(.nav-links) {
    background: rgba(4,6,14,0.95) !important;
  }

  main { position: relative; z-index: 10; }

  /* ── HERO: full viewport height, content over canvas ── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 1.5rem 2rem;
    text-align: center;
    pointer-events: none;
  }

  .hero-content {
    pointer-events: auto;
    max-width: 700px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,212,255,0.1);
    border: 1px solid rgba(0,212,255,0.25);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 20px;
    margin-bottom: 1.5rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .badge-dot {
