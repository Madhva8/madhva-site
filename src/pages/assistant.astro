---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AI Assistant | Madhva Fakare</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0f0f0f;
      color: #e0e0e0;
      height: 100vh;
      display: flex;
      overflow: hidden;
    }
    #sidebar {
      width: 260px;
      min-width: 260px;
      background: #111;
      border-right: 1px solid #222;
      display: flex;
      flex-direction: column;
      padding: 12px;
      gap: 8px;
      overflow: hidden;
    }
    #sidebar-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 4px 0 8px;
      border-bottom: 1px solid #222;
    }
    #sidebar-header a { color: #888; text-decoration: none; font-size: 0.8rem; }
    #sidebar-header a:hover { color: #fff; }
    #new-chat-btn {
      width: 100%;
      padding: 10px;
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 8px;
      color: #e0e0e0;
      cursor: pointer;
      font-size: 0.88rem;
      text-align: left;
      transition: background 0.2s;
    }
    #new-chat-btn:hover { background: #2a2a2a; }
    #sessions-list {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .session-item {
      padding: 8px 10px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.83rem;
      color: #aaa;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 6px;
      transition: background 0.2s;
    }
    .session-item:hover { background: #1e1e1e; }
    .session-item.active { background: #1e2a3a; color: #fff; }
    .session-title { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .session-date { font-size: 0.7rem; color: #555; white-space: nowrap; }
    .session-delete {
      background: none;
      border: none;
      color: #444;
      cursor: pointer;
      padding: 2px 4px;
      border-radius: 4px;
      font-size: 0.8rem;
      opacity: 0;
      transition: all 0.2s;
    }
    .session-item:hover .session-delete { opacity: 1; }
    .session-delete:hover { color: #ef4444; background: #2a1a1a; }
    #sidebar-footer { border-top: 1px solid #222; padding-top: 8px; }
    .model-btn {
      width: 100%;
      padding: 8px 10px;
      border-radius: 8px;
      border: 1px solid #333;
      background: #1a1a1a;
      color: #888;
      cursor: pointer;
      font-size: 0.83rem;
      text-align: left;
      transition: all 0.2s;
      margin-bottom: 4px;
    }
    .model-btn.active { background: #0070f3; color: white; border-color: #0070f3; }
    .model-btn:hover:not(.active) { background: #2a2a2a; color: #ccc; }
    #main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    #chat-header {
      padding: 14px 20px;
      border-bottom: 1px solid #1a1a1a;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    #chat-title { font-size: 0.95rem; color: #ccc; font-weight: 500; }
    #chat-subtitle { font-size: 0.75rem; color: #555; margin-top: 2px; }
    #status-bar {
      font-size: 0.72rem;
      color: #444;
      padding: 4px 20px;
      min-height: 20px;
      transition: color 0.3s;
    }
    #status-bar.saved { color: #22c55e; }
    #status-bar.error { color: #ef4444; }
    #chat-box {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .msg-wrapper { display: flex; flex-direction: column; max-width: 75%; gap: 4px; }
    .msg-wrapper.user { align-self: flex-end; align-items: flex-end; }
    .msg-wrapper.ai { align-self: flex-start; align-items: flex-start; }
    .msg-label { font-size: 0.7rem; color: #555; padding: 0 4px; }
    .msg {
      padding: 12px 16px;
      border-radius: 12px;
      line-height: 1.65;
      font-size: 0.92rem;
      white-space: pre-wrap;
      word-wrap: break-word;
    }
    .user-msg { background: #0070f3; color: white; border-radius: 12px 12px 4px 12px; }
    .ai-msg { background: #1e1e1e; color: #e0e0e0; border: 1px solid #2a2a2a; border-radius: 12px 12px 12px 4px; }
    .msg-actions { display: flex; gap: 4px; opacity: 0; transition: opacity 0.2s; }
    .msg-wrapper:hover .msg-actions { opacity: 1; }
    .msg-action-btn {
      background: #1a1a1a;
      border: 1px solid #333;
      color: #666;
      cursor: pointer;
      font-size: 0.72rem;
      padding: 3px 8px;
      border-radius: 4px;
      transition: all 0.2s;
    }
    .msg-action-btn:hover { background: #2a1a1a; color: #ef4444; border-color: #ef4444; }
    .typing {
      align-self: flex-start;
      background: #1e1e1e;
      border: 1px solid #2a2a2a;
      color: #666;
      padding: 12px 16px;
      border-radius: 12px;
      font-style: italic;
      font-size: 0.85rem;
    }
    .empty-state {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      color: #333;
    }
    .empty-state h2 { font-size: 1.4rem; color: #444; }
    .empty-state p { font-size: 0.85rem; color: #333; }
    #input-area {
      padding: 16px 20px;
      border-top: 1px solid #1a1a1a;
    }
    #input-row { display: flex; gap: 10px; }
    #user-input {
      flex: 1;
      padding: 12px 16px;
      border-radius: 10px;
      border: 1px solid #2a2a2a;
      background: #1a1a1a;
      color: #e0e0e0;
      font-size: 0.92rem;
      outline: none;
      transition: border-color 0.2s;
    }
    #user-input:focus { border-color: #0070f3; }
    #send-btn {
      padding: 12px 20px;
      background: #0070f3;
      color: white;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-size: 0.92rem;
      transition: background 0.2s;
    }
    #send-btn:hover { background: #005bb5; }
    #send-btn:disabled { background: #1a1a1a; color: #444; cursor: not-allowed; border: 1px solid #2a2a2a; }
    #input-hint { font-size: 0.72rem; color: #333; margin-top: 6px; text-align: center; }
  </style>
</head>
<body>

  <div id="sidebar">
    <div id="sidebar-header">
      <span style="font-size:0.85rem;color:#666;">🔬 Physics Assistant</span>
      <a href="/">← Site</a>
    </div>
    <button id="new-chat-btn" onclick="newChat()">✏️ New chat</button>
    <div id="sessions-list"></div>
    <div id="sidebar-footer">
      <button class="model-btn active" onclick="switchModel('gemini')" id="btn-gemini">✨ Gemini 2.5 Flash</button>
      <button class="model-btn" onclick="switchModel('deepseek')" id="btn-deepseek">🧠 DeepSeek</button>
    </div>
  </div>

  <div id="main">
    <div id="chat-header">
      <div>
        <div id="chat-title">New conversation</div>
        <div id="chat-subtitle">ALICE/TRD · Electron-Pion Separation</div>
      </div>
    </div>
    <div id="status-bar"></div>
    <div id="chat-box">
      <div class="empty-state" id="empty-state">
        <h2>🔬 Physics AI Assistant</h2>
        <p>Pre-loaded with your ALICE/TRD project context</p>
        <p>Ask about ROOT, O2Physics, TRD, BDT...</p>
      </div>
    </div>
    <div id="input-area">
      <div id="input-row">
        <input id="user-input" type="text" placeholder="Ask about ROOT, O2Physics, TRD..." autocomplete="off"/>
        <button id="send-btn" onclick="sendMessage()">Send</button>
      </div>
      <div id="input-hint">Enter to send · Switch models in sidebar</div>
    </div>
  </div>

  <script is:inline>
    const MASTER_CONTEXT = `You are a specialist physics AI assistant for Madhva Fakare, an MSc Physics student in Münster, Germany. Project: electron-pion separation using the TRD in ALICE at CERN. Stack: ROOT, O2Physics, lxplus/CVMFS, AO2D Run 3 data, BDT for particle ID, alice-trd-analysis GitHub repo. Focus: tpcSkimsTableCreator.cxx, CERNBox data, BDT ML pipeline, fSigned1Pt variable. Environment: M1 MacBook Sonoma, VS Code SSH to lxplus. Always give precise graduate-level technical answers. Default to C++ ROOT/O2Physics unless Python requested.`;

    const GEMINI_KEY = 'AIzaSyDJn8crTQ0kSwuRmKlh56B6Eu62DQ5SHTo';
    const DEEPSEEK_KEY = 'sk-b8653889f21b4f86bec501d959c3ef6e';
    const SUPABASE_URL = 'https://fvwpzmnjejxmzaczkpde.supabase.co';
    const SUPABASE_KEY = 'sb_publishable_Ayveuh9J65cAG6Yi9QLZgA_PP5i_GaK';

    let model = 'gemini';
    let history = [];
    let sessionId = null;
    let sessions = [];

    const chatBox = document.getElementById('chat-box');
    const input = document.getElementById('user-input');
    const sendBtn = document.getElementById('send-btn');
    const statusBar = document.getElementById('status-bar');

    function setStatus(msg, type) {
      statusBar.textContent = msg;
      statusBar.className = type || '';
      if (msg) setTimeout(() => { statusBar.textContent = ''; statusBar.className = ''; }, 3000);
    }

    async function saveMessage(role, content) {
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/messages`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${SUPABASE_KEY}`,
            'Prefer': 'return=representation'
          },
          body: JSON.stringify({ role, content, model, session_id: sessionId })
        });
        const data = await res.json();
        setStatus('✓ Saved', 'saved');
        return data[0]?.id || null;
      } catch { setStatus('⚠ Save failed', 'error'); return null; }
    }

    async function deleteMessageFromDB(msgId, wrapperEl) {
      try {
        await fetch(`${SUPABASE_URL}/rest/v1/messages?id=eq.${msgId}`, {
          method: 'DELETE',
          headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` }
        });
        wrapperEl.remove();
        setStatus('Message deleted', '');
      } catch { setStatus('⚠ Delete failed', 'error'); }
    }

    async function loadSessions() {
      try {
        const res = await fetch(
          `${SUPABASE_URL}/rest/v1/messages?select=session_id,created_at,content,role&order=created_at.asc`,
          { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` } }
        );
        const msgs = await res.json();
        const map = {};
        msgs.forEach(m => {
          if (!map[m.session_id]) map[m.session_id] = { id: m.session_id, first: m.content, date: m.created_at };
        });
        sessions = Object.values(map).reverse();
        renderSessions();
      } catch {}
    }

    function renderSessions() {
      const list = document.getElementById('sessions-list');
      list.innerHTML = '';
      if (sessions.length === 0) {
        list.innerHTML = '<div style="font-size:0.75rem;color:#333;padding:8px;">No past chats yet</div>';
        return;
      }
      sessions.forEach(s => {
        const el = document.createElement('div');
        el.className = 'session-item' + (s.id === sessionId ? ' active' : '');
        el.dataset.id = s.id;

        const title = document.createElement('span');
        title.className = 'session-title';
        title.textContent = s.first?.slice(0, 35) || 'New chat';

        const date = document.createElement('span');
        date.className = 'session-date';
        date.textContent = new Date(s.date).toLocaleDateString('en-GB', { day:'numeric', month:'short' });

        const del = document.createElement('button');
        del.className = 'session-delete';
        del.textContent = '✕';
        del.onclick = (e) => { e.stopPropagation(); deleteSession(s.id, el); };

        el.appendChild(title);
        el.appendChild(date);
        el.appendChild(del);
        el.onclick = () => loadSession(s.id);
        list.appendChild(el);
      });
    }

    async function loadSession(id) {
      sessionId = id;
      localStorage.setItem('chat_session_id', id);
      history = [];
      chatBox.innerHTML = '';
      document.querySelectorAll('.session-item').forEach(el => {
        el.classList.toggle('active', el.dataset.id === id);
      });
      try {
        const res = await fetch(
          `${SUPABASE_URL}/rest/v1/messages?session_id=eq.${id}&order=created_at.asc`,
          { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` } }
        );
        const msgs = await res.json();
        msgs.forEach(m => {
          appendMessage(m.id, m.content, m.role === 'user' ? 'user' : 'ai', m.model);
          history.push(model === 'gemini'
            ? (m.role === 'user' ? { role:'user', parts:[{text:m.content}] } : { role:'model', parts:[{text:m.content}] })
            : { role: m.role === 'assistant' ? 'assistant' : m.role, content: m.content }
          );
        });
        const firstMsg = msgs.find(m => m.role === 'user');
        document.getElementById('chat-title').textContent = firstMsg?.content?.slice(0, 50) || 'Conversation';
        setStatus(`Loaded ${msgs.length} messages`, 'saved');
      } catch { setStatus('⚠ Could not load session', 'error'); }
    }

    async function deleteSession(id, el) {
      if (!confirm('Delete this entire conversation?')) return;
      try {
        await fetch(`${SUPABASE_URL}/rest/v1/messages?session_id=eq.${id}`, {
          method: 'DELETE',
          headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` }
        });
        el.remove();
        sessions = sessions.filter(s => s.id !== id);
        if (id === sessionId) newChat();
        setStatus('Session deleted', '');
      } catch { setStatus('⚠ Delete failed', 'error'); }
    }

    function newChat() {
      sessionId = 'session_' + Date.now();
      localStorage.setItem('chat_session_id', sessionId);
      history = [];
      chatBox.innerHTML = `
        <div class="empty-state" id="empty-state">
          <h2>🔬 Physics AI Assistant</h2>
          <p>Pre-loaded with your ALICE/TRD project context</p>
          <p>Ask about ROOT, O2Physics, TRD, BDT...</p>
        </div>`;
      document.getElementById('chat-title').textContent = 'New conversation';
      document.querySelectorAll('.session-item').forEach(el => el.classList.remove('active'));
    }

    // ── KEY FIX: model switch does NOT clear messages or history ──
    function switchModel(m) {
      model = m;
      document.getElementById('btn-gemini').classList.toggle('active', m === 'gemini');
      document.getElementById('btn-deepseek').classList.toggle('active', m === 'deepseek');
      setStatus(`Switched to ${m === 'gemini' ? 'Gemini 2.5 Flash' : 'DeepSeek'}`, '');
    }

    function appendMessage(msgId, text, type, msgModel) {
      const empty = document.getElementById('empty-state');
      if (empty) empty.remove();

      const wrapper = document.createElement('div');
      wrapper.className = `msg-wrapper ${type}`;

      const label = document.createElement('div');
      label.className = 'msg-label';
      label.textContent = type === 'user' ? 'You' : (msgModel === 'deepseek' ? '🧠 DeepSeek' : '✨ Gemini 2.5 Flash');

      const el = document.createElement('div');
      el.className = `msg ${type === 'user' ? 'user-msg' : 'ai-msg'}`;
      el.textContent = text;

      const actions = document.createElement('div');
      actions.className = 'msg-actions';
      if (msgId) {
        const deleteBtn = document.createElement('button');
        deleteBtn.className = 'msg-action-btn';
        deleteBtn.textContent = '🗑 Delete';
        deleteBtn.onclick = () => deleteMessageFromDB(msgId, wrapper);
        actions.appendChild(deleteBtn);
      }

      wrapper.appendChild(label);
      wrapper.appendChild(el);
      wrapper.appendChild(actions);
      chatBox.appendChild(wrapper);
      chatBox.scrollTop = chatBox.scrollHeight;
      return wrapper;
    }

    async function sendMessage() {
      const msg = input.value.trim();
      if (!msg || sendBtn.disabled) return;

      input.value = '';
      sendBtn.disabled = true;

      const userMsgId = await saveMessage('user', msg);
      appendMessage(userMsgId, msg, 'user', 'user');
      document.getElementById('chat-title').textContent = msg.slice(0, 50);

      if (!sessions.find(s => s.id === sessionId)) {
        sessions.unshift({ id: sessionId, first: msg, date: new Date().toISOString() });
        renderSessions();
        document.querySelectorAll('.session-item')[0]?.classList.add('active');
      }

      const typing = document.createElement('div');
      typing.className = 'typing';
      typing.textContent = model === 'gemini' ? '✨ Gemini thinking...' : '🧠 DeepSeek thinking...';
      chatBox.appendChild(typing);
      chatBox.scrollTop = chatBox.scrollHeight;

      try {
        let reply = '';

        if (model === 'gemini') {
          history.push({ role: "user", parts: [{ text: msg }] });
          const res = await fetch(
            `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${GEMINI_KEY}`,
            {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                system_instruction: { parts: [{ text: MASTER_CONTEXT }] },
                contents: history
              })
            }
          );
          const data = await res.json();
          if (data.error) throw new Error(data.error.message);
          reply = data.candidates[0].content.parts[0].text;
          history.push({ role: "model", parts: [{ text: reply }] });
        } else {
          history.push({ role: "user", content: msg });
          const res = await fetch('https://api.deepseek.com/chat/completions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${DEEPSEEK_KEY}` },
            body: JSON.stringify({
              model: "deepseek-chat",
              messages: [{ role: "system", content: MASTER_CONTEXT }, ...history]
            })
          });
          const data = await res.json();
          if (data.error) throw new Error(data.error.message);
          reply = data.choices[0].message.content;
          history.push({ role: "assistant", content: reply });
        }

        chatBox.removeChild(typing);
        const aiMsgId = await saveMessage('assistant', reply);
        appendMessage(aiMsgId, reply, 'ai', model);

      } catch (err) {
        chatBox.removeChild(typing);
        appendMessage(null, 'Error: ' + err.message, 'ai', model);
      }

      sendBtn.disabled = false;
      input.focus();
    }

    input.addEventListener('keypress', e => { if (e.key === 'Enter') sendMessage(); });

    async function init() {
      await loadSessions();
      const saved = localStorage.getItem('chat_session_id');
      if (saved && sessions.find(s => s.id === saved)) {
        loadSession(saved);
      } else {
        newChat();
      }
    }

    init();
  </script>

</body>
</html>